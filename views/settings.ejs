<% var pageTitle = 'Settings'; var activePage = 'settings'; var solutions = []; %>
<%- include('partials/header', { solutions, pageTitle, activePage }) %>

<div class="section-header">
    <h2>Databricks Workspace Configuration</h2>
    <p>Manage multiple Databricks workspaces (Dev, QA, Production, etc.)</p>
</div>

<!-- Add New Workspace -->
<div class="clean-section">
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 15px;">
        <h3 style="margin-bottom: 0;">Add Workspace</h3>
    </div>
    <form id="addWorkspaceForm" style="max-width: 700px;">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
            <div>
                <label style="display: block; font-size: 0.85rem; font-weight: 600; color: var(--gray-700); margin-bottom: 6px;">Workspace Name *</label>
                <input type="text" id="wsName" required placeholder="e.g. MIT Dev Workspace"
                    style="width: 100%; padding: 10px 14px; border: 1px solid var(--border-medium); border-radius: 8px; font-size: 0.9rem; background: var(--gray-50);">
            </div>
            <div>
                <label style="display: block; font-size: 0.85rem; font-weight: 600; color: var(--gray-700); margin-bottom: 6px;">Environment *</label>
                <select id="wsEnv" style="width: 100%; padding: 10px 14px; border: 1px solid var(--border-medium); border-radius: 8px; font-size: 0.9rem; background: var(--gray-50);">
                    <option value="dev">Development</option>
                    <option value="qa">QA</option>
                    <option value="staging">Staging</option>
                    <option value="production">Production</option>
                </select>
            </div>
        </div>
        <div style="margin-top: 15px;">
            <label style="display: block; font-size: 0.85rem; font-weight: 600; color: var(--gray-700); margin-bottom: 6px;">Workspace URL *</label>
            <input type="text" id="wsUrl" required placeholder="e.g. https://adb-1234567890.12.azuredatabricks.net"
                style="width: 100%; padding: 10px 14px; border: 1px solid var(--border-medium); border-radius: 8px; font-size: 0.9rem; background: var(--gray-50);">
        </div>
        <div style="margin-top: 15px;">
            <label style="display: block; font-size: 0.85rem; font-weight: 600; color: var(--gray-700); margin-bottom: 6px;">Personal Access Token *</label>
            <input type="password" id="wsToken" required placeholder="dapi..."
                style="width: 100%; padding: 10px 14px; border: 1px solid var(--border-medium); border-radius: 8px; font-size: 0.9rem; background: var(--gray-50);">
        </div>
        <div style="margin-top: 15px; display: flex; gap: 12px; align-items: center;">
            <button type="submit" class="btn-blue" style="padding: 10px 24px; border: none; cursor: pointer; font-size: 0.85rem;">Add Workspace</button>
            <span id="addMsg" style="font-size: 0.85rem;"></span>
        </div>
    </form>
</div>

<!-- Existing Workspaces -->
<div class="clean-section" style="margin-top: 20px;">
    <h3>Configured Workspaces</h3>
    <p>These are the Databricks workspaces available for your solutions.</p>
    <div id="workspacesList" style="margin-top: 15px;">
        <% if (workspaces.length === 0) { %>
        <p style="color: var(--gray-500); font-size: 0.85rem;">No workspaces configured yet. Add one above.</p>
        <% } else { %>
        <div class="agents-grid-clean">
            <% workspaces.forEach(ws => { %>
            <div class="agent-card-clean" id="ws-<%= ws.id %>">
                <div class="agent-card-header">
                    <span class="agent-icon-clean">&#x2601;</span>
                    <span class="agent-badge-clean" style="<%= ws.environment === 'production' ? 'background: #ef4444; color: white; border-color: #ef4444;' : ws.environment === 'qa' ? 'background: #f59e0b; color: white; border-color: #f59e0b;' : ws.environment === 'staging' ? 'background: #8b5cf6; color: white; border-color: #8b5cf6;' : 'background: #3b82f6; color: white; border-color: #3b82f6;' %>"><%= ws.environment.toUpperCase() %></span>
                </div>
                <h4><%= ws.name %></h4>
                <p style="font-size: 0.75rem; color: var(--gray-400); word-break: break-all;"><%= ws.workspaceUrl %></p>
                <div class="agent-card-footer">
                    <button class="agent-try-now" onclick="testWorkspace('<%= ws.id %>')">Test Connection</button>
                    <span style="display: flex; gap: 8px;">
                        <button class="agent-try-now" style="background: var(--gray-600);" onclick="openEditWorkspace('<%= ws.id %>', '<%= ws.name %>', '<%= ws.environment %>', '<%= ws.workspaceUrl %>')">Edit</button>
                        <button style="background: none; border: none; cursor: pointer; color: #ef4444; font-size: 0.8rem; font-weight: 500;" onclick="deleteWorkspace('<%= ws.id %>')">Delete</button>
                    </span>
                </div>
            </div>
            <% }); %>
        </div>
        <% } %>
    </div>
</div>

<!-- Endpoints for selected workspace -->
<div class="clean-section" style="margin-top: 20px;">
    <h3>Serving Endpoints</h3>
    <p>Select a workspace to view its available agent serving endpoints.</p>
    <div style="margin-top: 10px; margin-bottom: 15px;">
        <select id="endpointWorkspace" onchange="loadEndpointsForWorkspace()" style="padding: 10px 14px; border: 1px solid var(--border-medium); border-radius: 8px; font-size: 0.9rem; background: var(--gray-50);">
            <option value="">-- Select a workspace --</option>
            <% workspaces.forEach(ws => { %>
            <option value="<%= ws.id %>"><%= ws.name %> (<%= ws.environment.toUpperCase() %>)</option>
            <% }); %>
        </select>
    </div>
    <div id="endpointsList">
        <p style="color: var(--gray-500); font-size: 0.85rem;">Select a workspace above to load endpoints.</p>
    </div>
</div>

<script>
// Add workspace
document.getElementById('addWorkspaceForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const msg = document.getElementById('addMsg');
    msg.style.color = 'var(--gray-600)';
    msg.textContent = 'Saving...';

    const res = await fetch('/api/workspaces', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            name: document.getElementById('wsName').value.trim(),
            environment: document.getElementById('wsEnv').value,
            workspaceUrl: document.getElementById('wsUrl').value.trim(),
            token: document.getElementById('wsToken').value.trim()
        })
    });
    if (res.ok) {
        msg.style.color = '#22c55e';
        msg.textContent = 'Workspace added!';
        setTimeout(() => window.location.reload(), 500);
    } else {
        const data = await res.json();
        msg.style.color = '#ef4444';
        msg.textContent = data.error || 'Error adding workspace.';
    }
});

// Test workspace connection
async function testWorkspace(id) {
    const card = document.getElementById('ws-' + id);
    const footer = card.querySelector('.agent-card-footer');
    const origHtml = footer.innerHTML;
    footer.innerHTML = '<span style="font-size: 0.8rem; color: var(--accent);">Testing...</span>';

    const res = await fetch('/api/workspaces/' + id + '/endpoints');
    const data = await res.json();

    if (data.error) {
        footer.innerHTML = '<span style="font-size: 0.8rem; color: #ef4444;">Failed: ' + data.error + '</span>';
    } else {
        footer.innerHTML = '<span style="font-size: 0.8rem; color: #22c55e;">Connected! ' + data.endpoints.length + ' endpoint(s)</span>';
    }
    setTimeout(() => { footer.innerHTML = origHtml; }, 3000);
}

// Delete workspace
async function deleteWorkspace(id) {
    if (!confirm('Delete this workspace? Solutions using it will need to be reassigned.')) return;
    await fetch('/api/workspaces/' + id, { method: 'DELETE' });
    window.location.reload();
}

// Load endpoints for selected workspace
async function loadEndpointsForWorkspace() {
    const wsId = document.getElementById('endpointWorkspace').value;
    const container = document.getElementById('endpointsList');
    if (!wsId) {
        container.innerHTML = '<p style="color: var(--gray-500); font-size: 0.85rem;">Select a workspace above to load endpoints.</p>';
        return;
    }
    container.innerHTML = '<p style="color: var(--accent); font-size: 0.85rem;">Loading endpoints...</p>';

    const res = await fetch('/api/workspaces/' + wsId + '/endpoints');
    const data = await res.json();

    if (data.error) {
        container.innerHTML = '<p style="color: #ef4444; font-size: 0.85rem;">Error: ' + data.error + '</p>';
        return;
    }
    if (data.endpoints.length === 0) {
        container.innerHTML = '<p style="color: var(--gray-500); font-size: 0.85rem;">No serving endpoints found.</p>';
        return;
    }
    container.innerHTML = '<div class="agents-grid-clean">' + data.endpoints.map(ep => {
        const isReady = ep.state === 'READY';
        const label = isReady ? 'READY' : 'STOPPED';
        const badgeStyle = isReady
            ? 'background: #22c55e; color: white; border-color: #22c55e;'
            : 'background: var(--gray-100); color: var(--gray-600);';
        return `
        <div class="agent-card-clean">
            <div class="agent-card-header">
                <span class="agent-icon-clean">&#x1f916;</span>
                <span class="agent-badge-clean" style="${badgeStyle}">${label}</span>
            </div>
            <h4>${ep.name}</h4>
            <p>Serving endpoint${ep.creator ? ' by ' + ep.creator : ''}</p>
        </div>`;
    }).join('') + '</div>';
}

// Edit workspace
let editingWsId = null;

function openEditWorkspace(id, name, env, url) {
    editingWsId = id;
    document.getElementById('editWsName').value = name;
    document.getElementById('editWsEnv').value = env;
    document.getElementById('editWsUrl').value = url;
    document.getElementById('editWsToken').value = '';
    document.getElementById('editWsToken').placeholder = '(leave blank to keep current token)';
    document.getElementById('editWsMsg').textContent = '';
    document.getElementById('editWsModal').style.display = 'flex';
}

function closeEditModal() {
    document.getElementById('editWsModal').style.display = 'none';
    editingWsId = null;
}

document.getElementById('editWsForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const msg = document.getElementById('editWsMsg');
    msg.style.color = 'var(--gray-600)';
    msg.textContent = 'Saving...';

    const body = {
        name: document.getElementById('editWsName').value.trim(),
        environment: document.getElementById('editWsEnv').value,
        workspaceUrl: document.getElementById('editWsUrl').value.trim()
    };
    const newToken = document.getElementById('editWsToken').value.trim();
    if (newToken) body.token = newToken;

    const res = await fetch('/api/workspaces/' + editingWsId, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
    });
    if (res.ok) {
        msg.style.color = '#22c55e';
        msg.textContent = 'Saved!';
        setTimeout(() => window.location.reload(), 500);
    } else {
        msg.style.color = '#ef4444';
        msg.textContent = 'Error saving workspace.';
    }
});
</script>

<!-- Edit Workspace Modal -->
<div id="editWsModal" class="modal-overlay" style="display:none;">
    <div class="modal-box">
        <div class="modal-header">
            <h3>Edit Workspace</h3>
            <button class="modal-close" onclick="closeEditModal()">&times;</button>
        </div>
        <form id="editWsForm">
            <div class="modal-body">
                <div style="margin-bottom: 16px;">
                    <label style="display: block; font-size: 0.85rem; font-weight: 600; color: var(--gray-700); margin-bottom: 6px;">Workspace Name *</label>
                    <input type="text" id="editWsName" required
                        style="width: 100%; padding: 10px 14px; border: 1px solid var(--border-medium); border-radius: 8px; font-size: 0.9rem;">
                </div>
                <div style="margin-bottom: 16px;">
                    <label style="display: block; font-size: 0.85rem; font-weight: 600; color: var(--gray-700); margin-bottom: 6px;">Environment</label>
                    <select id="editWsEnv" style="width: 100%; padding: 10px 14px; border: 1px solid var(--border-medium); border-radius: 8px; font-size: 0.9rem;">
                        <option value="dev">Development</option>
                        <option value="qa">QA</option>
                        <option value="staging">Staging</option>
                        <option value="production">Production</option>
                    </select>
                </div>
                <div style="margin-bottom: 16px;">
                    <label style="display: block; font-size: 0.85rem; font-weight: 600; color: var(--gray-700); margin-bottom: 6px;">Workspace URL *</label>
                    <input type="text" id="editWsUrl" required
                        style="width: 100%; padding: 10px 14px; border: 1px solid var(--border-medium); border-radius: 8px; font-size: 0.9rem;">
                </div>
                <div style="margin-bottom: 16px;">
                    <label style="display: block; font-size: 0.85rem; font-weight: 600; color: var(--gray-700); margin-bottom: 6px;">Personal Access Token</label>
                    <input type="password" id="editWsToken"
                        style="width: 100%; padding: 10px 14px; border: 1px solid var(--border-medium); border-radius: 8px; font-size: 0.9rem;">
                    <span style="font-size: 0.75rem; color: var(--gray-500); display: block; margin-top: 4px;">Leave blank to keep the current token</span>
                </div>
                <span id="editWsMsg" style="font-size: 0.85rem;"></span>
            </div>
            <div class="modal-footer">
                <button type="button" style="padding: 8px 20px; border: 1px solid var(--border-medium); border-radius: 8px; background: white; cursor: pointer; font-size: 0.85rem;" onclick="closeEditModal()">Cancel</button>
                <button type="submit" class="btn-blue" style="padding: 8px 20px; border: none; cursor: pointer; font-size: 0.85rem;">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<%- include('partials/footer') %>
