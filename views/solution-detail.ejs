// DRAG-AND-DROP FOR PIPELINE CARDS + AVAILABLE AGENTS PANEL
// ============================================================================

let draggedElement = null;

function initDragDrop() {
    console.log('[DRAGDROP] Initializing drag-drop');
    const pipeline = document.getElementById('workflowPipeline');
    if (!pipeline) {
        console.error('[DRAGDROP] Pipeline element not found');
        return false;
    }

    const cards = pipeline.querySelectorAll('.workflow-agent');
    console.log('[DRAGDROP] Found', cards.length, 'cards to make draggable');

    if (cards.length === 0) {
        console.warn('[DRAGDROP] No cards found, will retry later');
        return false;
    }

    cards.forEach((card, idx) => {
        // Ensure draggable attribute is set
        card.draggable = true;
        card.dataset.dragIndex = idx;

        // Add drag listeners
        card.addEventListener('dragstart', function(e) {
            draggedElement = this;
            e.dataTransfer.effectAllowed = 'move';
            this.style.opacity = '0.5';
            this.style.border = '2px dashed #3B82F6';
            console.log('[DRAGDROP] Drag started on card', idx);
        }, false);

        card.addEventListener('dragend', function(e) {
            this.style.opacity = '1';
            this.style.border = '';
            draggedElement = null;
            console.log('[DRAGDROP] Drag ended');
        }, false);

        card.addEventListener('dragover', function(e) {
            e.preventDefault();
            e.dataTransfer.dropEffect = 'move';
            if (draggedElement && draggedElement !== this) {
                this.style.borderLeft = '4px solid #3B82F6';
            }
        }, false);

        card.addEventListener('dragleave', function(e) {
            this.style.borderLeft = '';
        }, false);

        card.addEventListener('drop', function(e) {
            e.preventDefault();
            this.style.borderLeft = '';

            if (draggedElement && draggedElement !== this) {
                console.log('[DRAGDROP] Drop detected');
                const parent = pipeline;
                const allCards = [...parent.querySelectorAll('.workflow-agent')];
                const draggedIdx = allCards.indexOf(draggedElement);
                const targetIdx = allCards.indexOf(this);

                if (draggedIdx >= 0 && targetIdx >= 0) {
                    if (draggedIdx < targetIdx) {
                        this.parentNode.insertBefore(draggedElement, this.nextElementSibling);
                    } else {
                        this.parentNode.insertBefore(draggedElement, this);
                    }
                    saveWorkflowOrder();
                    console.log('[DRAGDROP] Cards reordered:', draggedIdx, '->', targetIdx);
                }
            }
        }, false);
    });

    console.log('[DRAGDROP] Drag-drop initialized successfully on', cards.length, 'cards');
    return true;
}

function saveWorkflowOrder() {
    const pipeline = document.getElementById('workflowPipeline');
    const cards = pipeline.querySelectorAll('.workflow-agent');
    const stepIds = Array.from(cards).map(c => c.dataset.stepId);

    fetch('/api/solutions/' + SOLUTION_ID + '/reorder', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ stepIds })
    }).then(() => {
        // Update the dynamic diagram after reordering
        generateDynamicDiagram();
        generateExecutionFlowCircles();
        console.log('[WORKFLOW] Order saved and diagram updated');
    }).catch(err => console.log('Save order error:', err));
}

