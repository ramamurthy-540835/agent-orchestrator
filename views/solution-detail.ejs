// Real-time executor timeline animation
function renderExecutionFlow(state) {
    const timeline = document.getElementById('executorTimeline');
    if (!timeline) return;

    const nodeOrder = [
        'profile', 'supervisor_profile',
        'quality', 'supervisor_quality',
        'classify', 'supervisor_classify',
        'autoloader', 'supervisor_autoloader',
        'complete'
    ];

    // Determine which nodes are completed from the log
    const completedAgents = new Set();
    const failedAgents = new Set();
    if (state.execution_log) {
        state.execution_log.forEach(entry => {
            if (entry.event_type === 'AGENT_RESULT') {
                completedAgents.add(entry.agent);
                if (entry.details?.status === 'FAILED') {
                    failedAgents.add(entry.agent);
                }
            }
            if (entry.event_type === 'SUPERVISOR_ANALYSIS') {
                const supervisor_name = 'supervisor_' + entry.details?.step?.replace('after_', '');
                if (supervisor_name !== 'supervisor_undefined') {
                    completedAgents.add(supervisor_name);
                }
            }
        });
    }

    let html = '<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 8px;">';

    nodeOrder.forEach(nodeName => {
        const isRunning = state.current_agent === nodeName;
        const isCompleted = completedAgents.has(nodeName) || (state.status === 'COMPLETED');
        const isFailed = failedAgents.has(nodeName);
        const isPaused = state.checkpoint_pending && nodeName === state.current_agent;

        let className = '';
        let emoji = '⭕';
        let bgColor = '#f3f4f6';
        let borderColor = '#d1d5db';

        if (state.status === 'COMPLETED') {
            className = 'node-completed';
            emoji = '✅';
            bgColor = '#10B981';
            borderColor = '#10B981';
        } else if (isFailed) {
            className = 'node-failed';
            emoji = '❌';
            bgColor = '#EF4444';
            borderColor = '#EF4444';
        } else if (isPaused) {
            className = 'node-paused';
            emoji = '⏸';
            bgColor = '#F59E0B';
            borderColor = '#F59E0B';
        } else if (isRunning) {
            className = 'node-running';
            emoji = '⚡';
            bgColor = '#3B82F6';
            borderColor = '#3B82F6';
        } else if (isCompleted) {
            className = 'node-completed';
            emoji = '✅';
            bgColor = '#10B981';
            borderColor = '#10B981';
        }

        const displayName = nodeName
            .replace(/_/g, ' ')
            .replace(/supervisor /gi, 'Sup.')
            .replace(/gate/gi, 'Gate');

        html += `
        <div class="${className}" style="background: ${bgColor}; border: 2px solid ${borderColor}; border-radius: 8px; padding: 12px 8px; text-align: center; font-size: 0.75rem; cursor: pointer; color: white; font-weight: 600; transition: all 0.3s;"
             title="${nodeName}" onclick="highlightLogEntry('${nodeName}')">
            <div style="font-size: 1.4rem; margin-bottom: 6px;">${emoji}</div>
            <div style="word-break: break-word; line-height: 1.2;">${displayName}</div>
        </div>`;
    });

    html += '</div>';
    timeline.innerHTML = html;
    console.log('[FLOW] Execution flow updated - completed: ' + Array.from(completedAgents).join(', '));
}

// Format log entry with color and emoji
function formatLogEntry(entry) {
    if (!entry || !entry.event_type) return '';

    const color = EVENT_COLORS[entry.event_type] || '#6b7280';
    const emoji = EVENT_EMOJI[entry.event_type] || '📝';
    const timestamp = entry.timestamp ? new Date(entry.timestamp).toLocaleTimeString() : '--:--:--';
    const agentName = entry.agent || entry.name || 'system';

    let detailsStr = '';
    const details = entry.details || {};

    switch(entry.event_type) {
        case 'AGENT_CALL':
            detailsStr = ` Calling ${agentName}...`;
            break;
        case 'AGENT_RESULT':
            if (details.status) detailsStr = ` [${details.status}]`;
            if (details.duration_ms) detailsStr += ` (${details.duration_ms}ms)`;
            break;
        case 'AGENT_RESULT_FAILED':
            if (details.error) detailsStr = ` Error: ${details.error.substring(0, 50)}...`;
            break;
        case 'ROUTING_DECISION':
            if (details.action) detailsStr = ` Route: ${details.action}`;
            if (details.reason) detailsStr += ` (${details.reason.substring(0, 40)})`;
            break;
        case 'SUPERVISOR_ANALYSIS':
            if (details.decision) detailsStr = ` Decision: ${details.decision.decision || ''}`;
            if (details.decision?.confidence) detailsStr += ` (${details.decision.confidence}%)`;
            break;
        case 'HUMAN_CHECKPOINT':
            if (details.question) detailsStr = ` ${details.question.substring(0, 50)}...`;
            break;
        case 'HUMAN_DECISION':
            if (details.decision) detailsStr = ` Human decided: ${details.decision}`;
            break;
        case 'WORKFLOW_COMPLETE':
            detailsStr = ' Pipeline execution complete!';
            break;
        default:
            if (details.message) detailsStr = ` ${details.message}`;
    }

    let agentSpan = agentName !== 'system' ? `<span style="color: #9CA3AF; font-size: 0.75rem;"> · ${agentName}</span>` : '';
    let detailsDiv = detailsStr ? `<div style="color: #555; font-size: 0.8rem; margin-top: 2px; line-height: 1.4;">${detailsStr}</div>` : '';

    return `
    <div style="background: white; border-left: 4px solid ${color}; padding: 10px 12px; margin-bottom: 6px; border-radius: 4px; font-size: 0.85rem; cursor: pointer; transition: all 0.2s;"
         onclick="expandLogEntry(this)">
        <div style="display: flex; gap: 8px; align-items: flex-start;">
            <span style="font-size: 1rem; flex-shrink: 0;">${emoji}</span>
            <div style="flex: 1; min-width: 0;">
                <strong style="color: ${color}; display: inline-block;">${entry.event_type}</strong>
                <span style="color: #9CA3AF; font-size: 0.75rem; margin-left: 6px;">@${timestamp}</span>
                ${agentSpan}
                ${detailsDiv}
            </div>
        </div>
    </div>`;
}

// Render log timeline
function renderLogTimeline(log) {
    const timeline = document.getElementById('logTimeline');
    if (!timeline) {
        console.warn('[LOG] Timeline element not found');
        return;
    }

    if (!log || log.length === 0) {
        timeline.innerHTML = '<div style="color: #9CA3AF; text-align: center; padding: 20px;">No log entries yet...</div>';
        return;
    }

    const html = log.map(entry => {
        if (!entry) return '';
        return formatLogEntry(entry);
    }).filter(h => h).join('');

    timeline.innerHTML = html;
    console.log('[LOG] Rendered', log.length, 'log entries');
}

