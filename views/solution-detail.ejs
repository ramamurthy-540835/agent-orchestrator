<% var pageTitle = solution.name; var activePage = ''; var solutions = [solution]; var activeSolution = solution.id; %>
<%- include('partials/header', { solutions, pageTitle, activePage, activeSolution }) %>

<!-- Solution Header -->
<div class="clean-header">
    <div class="clean-header-top">
        <h2><%= solution.name %></h2>
        <div style="display: flex; gap: 8px; flex-shrink: 0; align-items: center;">
            <span class="agent-badge-clean" style="font-size: 0.75rem;"><%= solution.status %></span>
            <% if (workspace) { %>
            <span class="agent-badge-clean" style="font-size: 0.75rem; <%= workspace.environment === 'production' ? 'background: #ef4444; color: white; border-color: #ef4444;' : workspace.environment === 'qa' ? 'background: #f59e0b; color: white; border-color: #f59e0b;' : workspace.environment === 'staging' ? 'background: #8b5cf6; color: white; border-color: #8b5cf6;' : 'background: #3b82f6; color: white; border-color: #3b82f6;' %>"><%= workspace.environment.toUpperCase() %> - <%= workspace.name %></span>
            <% } else { %>
            <span class="agent-badge-clean" style="font-size: 0.75rem; background: #f59e0b; color: white; border-color: #f59e0b;">No workspace</span>
            <% } %>
            <a href="/solutions/<%= solution.id %>/edit" class="btn-blue" style="font-size: 0.75rem; padding: 4px 12px;">Edit</a>
            <button class="btn-blue" style="font-size: 0.75rem; padding: 4px 12px; border: none; cursor: pointer; background: #ef4444;" onclick="deleteSolution()">Delete</button>
        </div>
    </div>
    <p><%= solution.description || 'No description provided' %></p>
    <p style="font-size: 0.75rem; color: var(--gray-400); margin-top: 4px;">Created: <%= new Date(solution.createdAt).toLocaleDateString() %> &bull; Updated: <%= new Date(solution.updatedAt).toLocaleDateString() %></p>
</div>

<!-- Workflow Designer -->
<div class="clean-section">
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 15px;">
        <h3 style="margin-bottom: 0;">Workflow Pipeline</h3>
        <button class="btn-blue" style="padding: 6px 16px; border: none; cursor: pointer; font-size: 0.8rem;" onclick="openAddStepModal()">
            + Add Agent Step
        </button>
    </div>
    <p style="margin-bottom: 15px;">Define the sequence of Databricks agent serving endpoints. Each agent's output becomes the next agent's input.</p>

    <div id="workflowContainer">
        <% if (solution.steps.length === 0) { %>
        <div id="emptyWorkflow" style="text-align: center; padding: 40px 20px; border: 2px dashed var(--border-medium); border-radius: 12px;">
            <div style="font-size: 2.5rem; margin-bottom: 10px; opacity: 0.3;">&#x1f504;</div>
            <p style="color: var(--gray-500); margin-bottom: 15px;">No agent steps added yet. Add your first agent to start building the workflow.</p>
            <button class="btn-blue" style="padding: 8px 20px; border: none; cursor: pointer;" onclick="openAddStepModal()">+ Add First Agent</button>
        </div>
        <% } %>
    </div>

    <!-- Visual Workflow -->
    <div id="workflowPipeline" class="workflow-pipeline" style="<%= solution.steps.length === 0 ? 'display:none;' : '' %>">
        <!-- Start Node -->
        <div class="workflow-node workflow-start">
            <div class="workflow-node-icon">&#x25B6;</div>
            <div class="workflow-node-label">Input</div>
        </div>

        <% solution.steps.sort((a,b) => a.order - b.order).forEach((step, idx) => { %>
        <div class="workflow-connector">
            <div class="connector-line"></div>
            <div class="connector-arrow">&#9654;</div>
        </div>
        <div class="workflow-node workflow-agent" data-step-id="<%= step.id %>" draggable="true">
            <div class="workflow-node-header">
                <span class="workflow-step-num"><%= idx + 1 %></span>
                <div class="workflow-node-actions">
                    <button class="wf-btn" title="Edit" onclick="editStep('<%= step.id %>')">&#9998;</button>
                    <button class="wf-btn wf-btn-danger" title="Remove" onclick="removeStep('<%= step.id %>')">&#10005;</button>
                </div>
            </div>
            <div class="workflow-node-icon">&#x1f916;</div>
            <div class="workflow-node-name"><%= step.name %></div>
            <div class="workflow-node-endpoint"><%= step.endpointName %></div>
            <div class="workflow-node-mapping"><%= step.inputMapping %></div>
        </div>
        <% }); %>

        <% if (solution.steps.length > 0) { %>
        <div class="workflow-connector">
            <div class="connector-line"></div>
            <div class="connector-arrow">&#9654;</div>
        </div>
        <div class="workflow-node workflow-end">
            <div class="workflow-node-icon">&#x1f3c1;</div>
            <div class="workflow-node-label">Output</div>
        </div>
        <% } %>
    </div>
</div>

<!-- LangGraph Orchestrator Visualization (Top Layer) -->
<div class="clean-section" style="margin-top: 15px;">
    <h3>LangGraph Orchestrator Structure</h3>
    <p style="font-size: 0.85rem; color: var(--gray-600); margin-bottom: 12px;">Autonomous supervisor-guided execution flow with intelligent decision-making</p>
    <div id="graphVisualization" style="background: #f9fafb; border: 1px solid var(--border-light); border-radius: 8px; padding: 16px; min-height: 200px; font-family: monospace; font-size: 0.85rem; overflow-x: auto;">
        <pre id="graphAscii" style="margin: 0; color: var(--gray-700);">Loading graph structure...</pre>
    </div>
</div>

<!-- Real-Time Execution Animator -->
<div class="clean-section" id="executorAnimatorSection" style="display:none; margin-top: 15px;">
    <h3>Live Execution Flow</h3>
    <div id="executorTimeline" style="background: #f9fafb; border: 1px solid var(--border-light); border-radius: 8px; padding: 12px;">
        <!-- Dynamically populated nodes -->
    </div>
</div>

<!-- State Inspector Panel -->
<div class="clean-section" id="stateInspectorSection" style="display:none; margin-top: 15px;">
    <div style="display: flex; justify-content: space-between; align-items: center;">
        <h3>Execution State Inspector</h3>
        <button class="btn-blue" style="font-size: 0.75rem; padding: 4px 10px; border: none; cursor: pointer;" onclick="toggleStateInspector()">Hide</button>
    </div>
    <div id="stateInspectorBody" style="background: #1E1E1E; color: #D4D4D4; padding: 12px; border-radius: 8px; font-family: monospace; font-size: 0.8rem; max-height: 400px; overflow-y: auto;">
        <!-- State details populated here -->
    </div>
</div>

<!-- Log Visualizer Panel -->
<div class="clean-section" id="logVisualizerSection" style="display:none; margin-top: 15px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
        <h3 style="margin: 0;">Execution Log</h3>
        <div style="display: flex; gap: 10px; align-items: center;">
            <span id="logLiveIndicator" style="font-size: 0.8rem; color: #22c55e; font-weight: 600;">● LIVE</span>
            <button class="btn-blue" style="font-size: 0.75rem; padding: 4px 10px; border: none; cursor: pointer;" onclick="toggleLogVisualizer()">Hide</button>
        </div>
    </div>
    <div id="logTimeline" style="background: #f9fafb; border: 1px solid var(--border-light); border-radius: 8px; padding: 12px; max-height: 500px; overflow-y: auto;">
        <!-- Log entries rendered here -->
    </div>
</div>

<!-- Execution Panel -->
<div class="clean-section" style="margin-top: 15px;">
    <h3>Execute Workflow</h3>
    <p>Provide an initial input and run the entire agent pipeline sequentially.</p>
    <div style="margin-top: 12px; max-width: 100%;">
        <label style="display: block; font-size: 0.85rem; font-weight: 600; color: var(--gray-700); margin-bottom: 6px;">Input Prompt / Data</label>
        <div style="position: relative;">
            <textarea id="execInput" rows="4" placeholder="Enter the input to send to the first agent in the workflow..."
                style="width: 100%; padding: 10px 40px 10px 14px; border: 1px solid var(--border-medium); border-radius: 8px; font-size: 0.9rem; background: var(--gray-50); resize: vertical; font-family: inherit;"></textarea>
            <label for="fileUpload" class="pin-upload-btn" title="Attach file">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48"/></svg>
            </label>
            <input type="file" id="fileUpload" style="display: none;" onchange="handleFileUpload(this)">
        </div>
        <div id="fileInfo" style="display: none; margin-top: 6px; font-size: 0.8rem; color: var(--gray-600); display: none; align-items: center; gap: 6px;">
            <span id="fileName"></span>
            <button type="button" onclick="removeFile()" style="background: none; border: none; cursor: pointer; color: #ef4444; font-size: 0.9rem;">&times;</button>
        </div>
        <div style="margin-top: 10px;">
            <label style="display: flex; align-items: center; gap: 8px; font-size: 0.85rem; color: var(--gray-700); cursor: pointer; margin-bottom: 10px;">
                <input type="checkbox" id="broadcastMode" style="width: 16px; height: 16px; accent-color: var(--accent);">
                <strong>Pass original file/input to all agents</strong>
                <span style="color: var(--gray-500); font-weight: 400;">(each agent receives the original input + context from previous steps)</span>
            </label>
            <div style="display: flex; gap: 10px; align-items: center;">
                <button class="btn-blue" id="executeBtn" style="padding: 10px 24px; border: none; cursor: pointer; font-size: 0.85rem;" onclick="executeWorkflow()" <%= solution.steps.length === 0 ? 'disabled' : '' %>>
                    &#x25B6; Execute Pipeline
                </button>
                <span id="execStatus" style="font-size: 0.85rem; color: var(--gray-500);"></span>
            </div>
        </div>
    </div>

    <!-- Results -->
    <div id="execResults" style="display: none; margin-top: 20px;">
        <h3 style="margin-bottom: 12px;">Execution Results</h3>
        <div id="execResultsBody"></div>
    </div>
</div>

<% if (solution.lastRun) { %>
<div class="clean-section" style="margin-top: 15px;">
    <details>
        <summary style="cursor: pointer; display: flex; align-items: center; gap: 10px; list-style: none;">
            <svg class="last-run-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--gray-500)" stroke-width="2" style="transition: transform 0.2s; flex-shrink: 0;"><polyline points="9 18 15 12 9 6"/></svg>
            <h3 style="margin: 0; display: inline;">Last Run</h3>
            <span style="font-size: 0.8rem; color: var(--gray-500);"><%= new Date(solution.lastRun.timestamp).toLocaleString() %></span>
            <span style="font-size: 0.75rem; margin-left: auto; color: var(--gray-400);"><%= solution.lastRun.results.length %> step<%= solution.lastRun.results.length !== 1 ? 's' : '' %> &bull; <%= solution.lastRun.results.every(r => r.status === 'success') ? '<span style="color: #22c55e;">All passed</span>' : '<span style="color: #ef4444;">Has errors</span>' %></span>
        </summary>
        <div style="margin-top: 12px;">
            <% solution.lastRun.results.forEach((r, i) => { %>
            <div style="background: var(--gray-50); border: 1px solid var(--border-light); border-radius: 8px; padding: 12px; margin-bottom: 8px; border-left: 3px solid <%= r.status === 'success' ? '#22c55e' : '#ef4444' %>;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px;">
                    <strong style="font-size: 0.85rem;">Step <%= i + 1 %>: <%= r.stepName %></strong>
                    <span style="font-size: 0.75rem; color: <%= r.status === 'success' ? '#22c55e' : '#ef4444' %>; font-weight: 600;"><%= r.status.toUpperCase() %> (<%= r.duration %>ms)</span>
                </div>
                <div style="font-size: 0.8rem; color: var(--gray-500);">Endpoint: <%= r.endpoint %></div>
                <% if (r.error) { %>
                <div style="font-size: 0.8rem; color: #ef4444; margin-top: 6px;">Error: <%= r.error %></div>
                <% } %>
                <% if (r.output) { %>
                <details style="margin-top: 8px;">
                    <summary style="font-size: 0.8rem; cursor: pointer; color: var(--accent); font-weight: 500;">View Output</summary>
                    <pre style="background: #1E1E1E; color: #D4D4D4; padding: 12px; border-radius: 8px; margin-top: 6px; font-size: 0.8rem; overflow-x: auto; white-space: pre-wrap; max-height: 400px; overflow-y: auto;"><%= typeof r.output === 'string' ? r.output : JSON.stringify(r.output, null, 2) %></pre>
                </details>
                <% } %>
            </div>
            <% }); %>
        </div>
    </details>
</div>
<% } %>

<!-- Add/Edit Step Modal -->
<div id="stepModal" class="modal-overlay" style="display:none;">
    <div class="modal-box">
        <div class="modal-header">
            <h3 id="modalTitle">Add Agent Step</h3>
            <button class="modal-close" onclick="closeModal()">&times;</button>
        </div>
        <form id="stepForm">
            <div class="modal-body">
                <div style="margin-bottom: 16px;">
                    <label style="display: block; font-size: 0.85rem; font-weight: 600; color: var(--gray-700); margin-bottom: 6px;">Step Name *</label>
                    <input type="text" id="stepName" required placeholder="e.g. Document Classifier"
                        style="width: 100%; padding: 10px 14px; border: 1px solid var(--border-medium); border-radius: 8px; font-size: 0.9rem;">
                </div>
                <div style="margin-bottom: 16px;">
                    <label style="display: block; font-size: 0.85rem; font-weight: 600; color: var(--gray-700); margin-bottom: 6px;">Databricks Serving Endpoint *</label>
                    <div style="display: flex; gap: 8px;">
                        <select id="stepEndpoint" style="flex: 1; padding: 10px 14px; border: 1px solid var(--border-medium); border-radius: 8px; font-size: 0.9rem;">
                            <option value="">-- Select or type an endpoint --</option>
                        </select>
                        <button type="button" class="btn-blue" style="padding: 8px 14px; border: none; cursor: pointer; font-size: 0.8rem; white-space: nowrap;" onclick="loadEndpoints()">Refresh</button>
                    </div>
                    <input type="text" id="stepEndpointCustom" placeholder="Or type endpoint name manually"
                        style="width: 100%; padding: 10px 14px; border: 1px solid var(--border-medium); border-radius: 8px; font-size: 0.9rem; margin-top: 8px;">
                </div>
                <div style="margin-bottom: 16px;">
                    <label style="display: block; font-size: 0.85rem; font-weight: 600; color: var(--gray-700); margin-bottom: 6px;">Input Mapping</label>
                    <select id="stepMapping" style="width: 100%; padding: 10px 14px; border: 1px solid var(--border-medium); border-radius: 8px; font-size: 0.9rem;">
                        <option value="passthrough">Passthrough (auto-wrap in messages format)</option>
                        <option value="messages">Messages format (ChatCompletion style)</option>
                        <option value="input_array">Input Array format (Databricks agent schema)</option>
                        <option value="dataframe_split">DataFrame Split format</option>
                    </select>
                    <span style="font-size: 0.75rem; color: var(--gray-500); display: block; margin-top: 4px;">How to format the input for this agent's serving endpoint</span>
                </div>
                <div style="margin-bottom: 16px;">
                    <label style="display: block; font-size: 0.85rem; font-weight: 600; color: var(--gray-700); margin-bottom: 6px;">Description</label>
                    <textarea id="stepDesc" rows="2" placeholder="What does this agent do?"
                        style="width: 100%; padding: 10px 14px; border: 1px solid var(--border-medium); border-radius: 8px; font-size: 0.9rem; font-family: inherit;"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" style="padding: 8px 20px; border: 1px solid var(--border-medium); border-radius: 8px; background: white; cursor: pointer; font-size: 0.85rem;" onclick="closeModal()">Cancel</button>
                <button type="submit" class="btn-blue" style="padding: 8px 20px; border: none; cursor: pointer; font-size: 0.85rem;">Save Step</button>
            </div>
        </form>
    </div>
</div>

<script>
const SOLUTION_ID = '<%= solution.id %>';
let editingStepId = null;
let uploadedFileContent = null;

// File upload handling
function handleFileUpload(input) {
    const file = input.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = function(e) {
        uploadedFileContent = e.target.result;
        document.getElementById('fileName').textContent = file.name + ' (' + (file.size / 1024).toFixed(1) + ' KB)';
        document.getElementById('fileInfo').style.display = 'flex';
    };
    reader.readAsText(file);
}

function removeFile() {
    uploadedFileContent = null;
    document.getElementById('fileUpload').value = '';
    document.getElementById('fileInfo').style.display = 'none';
}

// Load endpoints into the dropdown
async function loadEndpoints() {
    const select = document.getElementById('stepEndpoint');
    select.innerHTML = '<option value="">Loading...</option>';
    try {
        const wsId = '<%= solution.workspaceId || '' %>';
        const res = await fetch(wsId ? '/api/workspaces/' + wsId + '/endpoints' : '/api/endpoints');
        const data = await res.json();
        select.innerHTML = '<option value="">-- Select an endpoint --</option>';
        if (data.endpoints && data.endpoints.length > 0) {
            data.endpoints.forEach(ep => {
                const opt = document.createElement('option');
                opt.value = ep.name;
                opt.textContent = ep.name + (ep.state !== 'READY' ? ' (' + ep.state + ')' : '');
                select.appendChild(opt);
            });
        } else {
            select.innerHTML = '<option value="">No endpoints found (type manually below)</option>';
        }
    } catch {
        select.innerHTML = '<option value="">Error loading (type manually below)</option>';
    }
}

function openAddStepModal() {
    editingStepId = null;
    document.getElementById('modalTitle').textContent = 'Add Agent Step';
    document.getElementById('stepName').value = '';
    document.getElementById('stepEndpoint').value = '';
    document.getElementById('stepEndpointCustom').value = '';
    document.getElementById('stepMapping').value = 'passthrough';
    document.getElementById('stepDesc').value = '';
    document.getElementById('stepModal').style.display = 'flex';
    loadEndpoints();
}

function editStep(stepId) {
    editingStepId = stepId;
    const node = document.querySelector(`[data-step-id="${stepId}"]`);
    document.getElementById('modalTitle').textContent = 'Edit Agent Step';
    document.getElementById('stepName').value = node.querySelector('.workflow-node-name').textContent;
    document.getElementById('stepEndpointCustom').value = node.querySelector('.workflow-node-endpoint').textContent;
    document.getElementById('stepMapping').value = node.querySelector('.workflow-node-mapping').textContent;
    document.getElementById('stepDesc').value = '';
    document.getElementById('stepModal').style.display = 'flex';
    loadEndpoints();
}

function closeModal() {
    document.getElementById('stepModal').style.display = 'none';
    editingStepId = null;
}

document.getElementById('stepForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const endpoint = document.getElementById('stepEndpointCustom').value.trim() || document.getElementById('stepEndpoint').value;
    if (!endpoint) { alert('Please select or type an endpoint name.'); return; }

    const body = {
        name: document.getElementById('stepName').value.trim(),
        endpointName: endpoint,
        inputMapping: document.getElementById('stepMapping').value,
        description: document.getElementById('stepDesc').value.trim()
    };

    let url, method;
    if (editingStepId) {
        url = '/api/solutions/' + SOLUTION_ID + '/steps/' + editingStepId;
        method = 'PUT';
    } else {
        url = '/api/solutions/' + SOLUTION_ID + '/steps';
        method = 'POST';
    }

    await fetch(url, { method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
    window.location.reload();
});

async function removeStep(stepId) {
    if (!confirm('Remove this agent step from the workflow?')) return;
    await fetch('/api/solutions/' + SOLUTION_ID + '/steps/' + stepId, { method: 'DELETE' });
    window.location.reload();
}

async function deleteSolution() {
    if (!confirm('Are you sure you want to delete this entire solution? This cannot be undone.')) return;
    await fetch('/api/solutions/' + SOLUTION_ID, { method: 'DELETE' });
    window.location = '/';
}

// Execute the workflow
async function executeWorkflow() {
    let input = document.getElementById('execInput').value.trim();
    if (!input && !uploadedFileContent) { alert('Please enter an input prompt or attach a file.'); return; }
    if (uploadedFileContent) {
        input = input ? input + '\n\n[Attached File Content]\n' + uploadedFileContent : uploadedFileContent;
    }

    const btn = document.getElementById('executeBtn');
    const status = document.getElementById('execStatus');
    btn.disabled = true;
    btn.textContent = 'Executing...';
    status.textContent = 'Running pipeline...';
    status.style.color = 'var(--accent)';

    try {
        const res = await fetch('/api/solutions/' + SOLUTION_ID + '/execute', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ input, broadcastMode: document.getElementById('broadcastMode').checked })
        });
        const data = await res.json();

        if (!res.ok) {
            status.textContent = data.error || 'Execution failed.';
            status.style.color = '#ef4444';
            btn.disabled = false;
            btn.innerHTML = '&#x25B6; Execute Pipeline';
            return;
        }

        status.textContent = 'Completed!';
        status.style.color = '#22c55e';
        renderResults(data.results, data.finalOutput);
    } catch (err) {
        status.textContent = 'Error: ' + err.message;
        status.style.color = '#ef4444';
    }

    btn.disabled = false;
    btn.innerHTML = '&#x25B6; Execute Pipeline';
}

function renderResults(results, finalOutput) {
    const container = document.getElementById('execResults');
    const body = document.getElementById('execResultsBody');
    container.style.display = 'block';

    let html = '';
    results.forEach((r, i) => {
        const color = r.status === 'success' ? '#22c55e' : '#ef4444';
        html += `
        <div style="background: var(--gray-50); border: 1px solid var(--border-light); border-radius: 8px; padding: 14px; margin-bottom: 10px; border-left: 3px solid ${color};">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                <strong style="font-size: 0.9rem;">Step ${i + 1}: ${r.stepName}</strong>
                <span style="font-size: 0.75rem; color: ${color}; font-weight: 600;">${r.status.toUpperCase()} (${r.duration}ms)</span>
            </div>
            <div style="font-size: 0.8rem; color: var(--gray-500); margin-bottom: 6px;">Endpoint: ${r.endpoint}</div>
            ${r.error ? `<div style="font-size: 0.8rem; color: #ef4444;">Error: ${r.error}</div>` : ''}
            ${r.output ? `
            <details style="margin-top: 8px;">
                <summary style="font-size: 0.8rem; cursor: pointer; color: var(--accent); font-weight: 500;">View Output</summary>
                <pre style="background: #1E1E1E; color: #D4D4D4; padding: 12px; border-radius: 8px; margin-top: 6px; font-size: 0.8rem; overflow-x: auto; white-space: pre-wrap;">${typeof r.output === 'string' ? escapeHtml(r.output) : escapeHtml(JSON.stringify(r.output, null, 2))}</pre>
            </details>` : ''}
        </div>`;
    });

    if (finalOutput) {
        html += `
        <div style="background: var(--gray-50); border: 2px solid #22c55e; border-radius: 8px; padding: 14px; margin-top: 15px;">
            <strong style="font-size: 0.9rem; color: #22c55e;">Final Output</strong>
            <pre style="background: #1E1E1E; color: #D4D4D4; padding: 12px; border-radius: 8px; margin-top: 8px; font-size: 0.85rem; overflow-x: auto; white-space: pre-wrap;">${typeof finalOutput === 'string' ? escapeHtml(finalOutput) : escapeHtml(JSON.stringify(finalOutput, null, 2))}</pre>
        </div>`;
    }

    body.innerHTML = html;
}

function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
}

// Drag and drop reordering
let draggedEl = null;
document.querySelectorAll('.workflow-agent').forEach(node => {
    node.addEventListener('dragstart', (e) => {
        draggedEl = node;
        node.style.opacity = '0.4';
    });
    node.addEventListener('dragend', () => {
        node.style.opacity = '1';
        draggedEl = null;
    });
    node.addEventListener('dragover', (e) => { e.preventDefault(); });
    node.addEventListener('drop', async (e) => {
        e.preventDefault();
        if (!draggedEl || draggedEl === node) return;
        const allNodes = [...document.querySelectorAll('.workflow-agent')];
        const fromIdx = allNodes.indexOf(draggedEl);
        const toIdx = allNodes.indexOf(node);
        if (fromIdx < toIdx) {
            node.parentNode.insertBefore(draggedEl.previousElementSibling, node.nextElementSibling);
            node.parentNode.insertBefore(draggedEl, node.nextElementSibling);
        } else {
            node.parentNode.insertBefore(draggedEl, node);
            node.parentNode.insertBefore(draggedEl.nextElementSibling || draggedEl, node);
        }
        const newOrder = [...document.querySelectorAll('.workflow-agent')].map(n => n.dataset.stepId);
        await fetch('/api/solutions/' + SOLUTION_ID + '/reorder', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ stepIds: newOrder })
        });
        window.location.reload();
    });
});

// ============================================================================
// LANGGRAPH VISUALIZER + REAL-TIME EXECUTION ANIMATOR
// ============================================================================

// Event type colors for log visualization
const EVENT_COLORS = {
    'AGENT_CALL': '#3b82f6',        // blue 🔵
    'AGENT_RESULT': '#22c55e',      // green ✅
    'AGENT_RESULT_FAILED': '#ef4444', // red ❌
    'ROUTING_DECISION': '#a855f7',  // purple 🔀
    'HUMAN_CHECKPOINT': '#f59e0b',  // orange ⚠️
    'HUMAN_DECISION': '#14b8a6',    // teal 👤
    'SUPERVISOR_ANALYSIS': '#6366f1', // indigo 🧠
    'WORKFLOW_COMPLETE': '#22c55e'  // green 🏁
};

const EVENT_EMOJI = {
    'AGENT_CALL': '🔵',
    'AGENT_RESULT': '✅',
    'AGENT_RESULT_FAILED': '❌',
    'ROUTING_DECISION': '🔀',
    'HUMAN_CHECKPOINT': '⚠️',
    'HUMAN_DECISION': '👤',
    'SUPERVISOR_ANALYSIS': '🧠',
    'WORKFLOW_COMPLETE': '🏁'
};

// Render LangGraph structure (ASCII diagram)
function renderGraphStructure() {
    const steps = document.querySelectorAll('[data-step-id]');
    const stepNames = Array.from(steps).map(s => s.querySelector('.workflow-node-name').textContent);

    const ascii = `
  START
    │
    ├─→ [Profile Agent]
    │   └─→ [Supervisor] (analyze log)
    │       ↓
    ├─→ [Quality Agent]
    │   └─→ [Supervisor] (check quality, confidence)
    │       ↓
    ├─→ [Quality Gate] ← if score < 60: escalate to human
    │   └─→ auto-approve (>80%) or auto-escalate (<60%)
    │       ↓
    ├─→ [Classify Agent] ${stepNames.includes('classifier') ? '✓' : '(if enabled)'}
    │   └─→ [Supervisor] (check PII, anomalies)
    │       ↓
    ├─→ [PII Gate] ← if CRITICAL: escalate to human
    │   └─→ auto-approve or escalate
    │       ↓
    ├─→ [AutoLoader Agent]
    │   └─→ [Supervisor] (check generated code)
    │       ↓
    ├─→ [Pipeline Review] ← if CRITICAL: manual review
    │   └─→ Approve/Modify/Abort
    │       ↓
    └─→ [Complete]
        └─→ END

  🧠 Supervisor Decision Flow:
     If confidence >= 90%: AUTO-PROCEED
     If 60% <= confidence < 90%: ESCALATE to human
     If confidence < 60%: HALT
    `;

    document.getElementById('graphAscii').textContent = ascii;
}

// Real-time executor timeline animation
function renderExecutionFlow(state) {
    const timeline = document.getElementById('executorTimeline');
    const nodeOrder = [
        'profile', 'supervisor_after_profile',
        'quality', 'supervisor_after_quality', 'quality_gate',
        'classify', 'supervisor_after_classify', 'pii_gate',
        'autoloader', 'supervisor_after_autoloader',
        'pipeline_review', 'complete'
    ];

    let html = '<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 8px;">';

    nodeOrder.forEach(nodeName => {
        const isRunning = state.current_agent === nodeName;
        const isCompleted = state.execution_log && state.execution_log.some(
            e => e.agent === nodeName && (e.event_type === 'AGENT_RESULT' || e.event_type === 'ROUTING_DECISION')
        );
        const isFailed = state.execution_log && state.execution_log.some(
            e => e.agent === nodeName && e.event_type === 'AGENT_RESULT' && e.details?.status === 'FAILED'
        );

        let bgColor = '#f3f4f6';  // default gray
        let borderColor = '#d1d5db';
        let emoji = '⭕';

        if (isFailed) {
            bgColor = '#fee2e2';
            borderColor = '#ef4444';
            emoji = '❌';
        } else if (isRunning) {
            bgColor = '#dbeafe';
            borderColor = '#3b82f6';
            emoji = '⚡';
        } else if (isCompleted) {
            bgColor = '#dcfce7';
            borderColor = '#22c55e';
            emoji = '✅';
        }

        const displayName = nodeName.replace(/_/g, ' ').replace(/supervisor after/, 'Supervisor').replace(/gate/, 'Gate');

        html += `
        <div style="background: ${bgColor}; border: 2px solid ${borderColor}; border-radius: 8px; padding: 10px; text-align: center; font-size: 0.75rem; cursor: pointer;"
             title="${nodeName}" onclick="highlightLogEntry('${nodeName}')">
            <div style="font-size: 1.2rem; margin-bottom: 4px;">${emoji}</div>
            <div style="font-weight: 600;">${displayName}</div>
        </div>`;
    });

    html += '</div>';
    timeline.innerHTML = html;
}

// Format log entry with color and emoji
function formatLogEntry(entry) {
    const color = EVENT_COLORS[entry.event_type] || '#6b7280';
    const emoji = EVENT_EMOJI[entry.event_type] || '📝';
    const timestamp = new Date(entry.timestamp).toLocaleTimeString();
    const agentName = entry.agent || 'system';

    let detailsStr = '';
    if (entry.details) {
        if (entry.event_type === 'AGENT_RESULT') {
            detailsStr = ` [${entry.details.status}] (${entry.details.duration_ms}ms)`;
        } else if (entry.event_type === 'ROUTING_DECISION') {
            detailsStr = ` ${entry.details.action || ''} ${entry.details.reason ? '(' + entry.details.reason.substring(0, 50) + '...)' : ''}`;
        } else if (entry.event_type === 'SUPERVISOR_ANALYSIS') {
            detailsStr = ` [${entry.details.decision?.decision}] confidence: ${entry.details.decision?.confidence}%`;
        } else if (entry.details.quality_score !== undefined) {
            detailsStr = ` (score: ${entry.details.quality_score}%)`;
        }
    }

    return `
    <div style="background: white; border-left: 4px solid ${color}; padding: 8px 12px; margin-bottom: 6px; border-radius: 4px; font-size: 0.85rem; cursor: pointer;"
         onclick="expandLogEntry(this)">
        <div style="display: flex; gap: 8px; align-items: center;">
            <span style="font-size: 1.2rem;">${emoji}</span>
            <div style="flex: 1;">
                <strong style="color: ${color};">${entry.event_type}</strong>
                <span style="color: #6b7280; font-size: 0.8rem;"> · ${agentName} · ${timestamp}</span>
                <div style="color: #555; font-size: 0.8rem;">${detailsStr}</div>
            </div>
        </div>
    </div>`;
}

// Render log timeline
function renderLogTimeline(log) {
    const timeline = document.getElementById('logTimeline');
    timeline.innerHTML = log.map(entry => formatLogEntry(entry)).join('');
}

// Toggle log visualizer visibility
function toggleLogVisualizer() {
    const section = document.getElementById('logVisualizerSection');
    section.style.display = section.style.display === 'none' ? 'block' : 'none';
}

// Toggle state inspector visibility
function toggleStateInspector() {
    const section = document.getElementById('stateInspectorSection');
    section.style.display = section.style.display === 'none' ? 'block' : 'none';
}

// Render state inspector
function renderStateInspector(state) {
    const inspector = document.getElementById('stateInspectorBody');
    const stateStr = JSON.stringify({
        workflow_id: state.workflow_id,
        status: state.status,
        current_agent: state.current_agent,
        current_step: state.current_step,
        quality_score: state.quality_score,
        pii_detected: state.pii_detected,
        supervisor_guidance: state.supervisor_guidance?.substring(0, 100),
        checkpoint_pending: state.human_checkpoint_pending,
        checkpoint_type: state.checkpoint_type,
        results_count: Object.keys(state.results || {}).length,
        log_entries: (state.execution_log || []).length,
        human_decisions: (state.human_decisions || []).length
    }, null, 2);
    inspector.textContent = stateStr;
}

// Log polling variables
let logPollingInterval = null;
let currentWorkflowId = null;

// Start polling for logs
function startLogPolling(workflowId) {
    currentWorkflowId = workflowId;

    // Show visualization sections
    document.getElementById('executorAnimatorSection').style.display = 'block';
    document.getElementById('logVisualizerSection').style.display = 'block';
    document.getElementById('stateInspectorSection').style.display = 'block';

    // Render initial graph structure
    renderGraphStructure();

    // Poll every 1 second for live updates
    logPollingInterval = setInterval(() => fetchAndUpdateLogs(workflowId), 1000);

    // First fetch immediately
    fetchAndUpdateLogs(workflowId);
}

// Fetch and update logs in real-time
async function fetchAndUpdateLogs(workflowId) {
    try {
        const resp = await fetch(`/api/orchestration/${workflowId}`);
        const data = await resp.json();

        if (!data) return;

        // Update executor animation
        renderExecutionFlow(data);

        // Update log timeline
        if (data.execution_log) {
            renderLogTimeline(data.execution_log);
            // Auto-scroll to bottom
            const timeline = document.getElementById('logTimeline');
            timeline.scrollTop = timeline.scrollHeight;
        }

        // Update state inspector
        renderStateInspector(data);

        // Update live indicator
        const indicator = document.getElementById('logLiveIndicator');
        if (['COMPLETED', 'FAILED', 'HALTED'].includes(data.status)) {
            clearInterval(logPollingInterval);
            indicator.textContent = `⏹ ${data.status}`;
            indicator.style.color = data.status === 'COMPLETED' ? '#22c55e' : '#ef4444';
        } else {
            indicator.textContent = '● LIVE';
            indicator.style.color = '#22c55e';
        }

        // Check for pending human checkpoint
        if (data.human_checkpoint_pending && data.checkpoint_details) {
            showHumanCheckpointModal(data);
        }

    } catch (err) {
        console.error('Error fetching logs:', err);
    }
}

// Show human checkpoint modal with supervisor guidance
function showHumanCheckpointModal(state) {
    const details = state.checkpoint_details || {};
    const guidance = details.supervisor_guidance || 'No guidance available';
    const checkpointType = state.checkpoint_type || 'CHECKPOINT';

    let contentHtml = `
    <div style="background: #f9fafb; border: 1px solid var(--border-light); border-radius: 8px; padding: 14px; margin-bottom: 14px;">
        <div style="display: flex; gap: 10px; align-items: flex-start;">
            <span style="font-size: 1.5rem;">🧠</span>
            <div>
                <strong style="color: #6366f1;">Supervisor Guidance</strong>
                <p style="margin: 6px 0 0; color: #555; font-size: 0.9rem;">${guidance}</p>
            </div>
        </div>
    </div>`;

    if (checkpointType.includes('QUALITY')) {
        contentHtml += `
        <div style="background: #e0f2fe; border: 1px solid #0284c7; border-radius: 8px; padding: 12px; margin-bottom: 14px;">
            <strong style="color: #0284c7;">Quality Score</strong>
            <p style="margin: 4px 0 0; color: #0c4a6e; font-size: 0.85rem;">${state.quality_score || 0}%</p>
        </div>`;
    }

    if (checkpointType.includes('PII') && state.pii_detected?.length) {
        contentHtml += `
        <div style="background: #fee2e2; border: 1px solid #ef4444; border-radius: 8px; padding: 12px; margin-bottom: 14px;">
            <strong style="color: #ef4444;">PII Detected</strong>
            <p style="margin: 4px 0 0; color: #7f1d1d; font-size: 0.85rem;">${state.pii_detected.join(', ')}</p>
        </div>`;
    }

    // Create and show modal (you can use your existing modal or create new one)
    const modal = document.createElement('div');
    modal.className = 'modal-overlay';
    modal.style.display = 'flex';
    modal.style.zIndex = '9999';
    modal.innerHTML = `
    <div class="modal-box" style="max-width: 500px;">
        <div class="modal-header">
            <h3 style="margin: 0;">Human Intervention Required</h3>
            <button class="modal-close" onclick="this.closest('.modal-overlay').remove()">&times;</button>
        </div>
        <div class="modal-body">
            ${contentHtml}
            <div style="background: #f9fafb; border: 1px solid var(--border-light); border-radius: 8px; padding: 12px;">
                <strong>Decision:</strong>
                <p style="margin: 6px 0 0; color: #555; font-size: 0.85rem;">Review the guidance above and choose an action.</p>
            </div>
        </div>
        <div class="modal-footer">
            <button style="padding: 8px 20px; border: 1px solid var(--border-medium); border-radius: 8px; background: white; cursor: pointer; font-size: 0.85rem;"
                    onclick="submitCheckpointDecision('approve', '${currentWorkflowId}', this.closest('.modal-overlay'))">✓ Approve</button>
            <button style="padding: 8px 20px; border: 1px solid var(--border-medium); border-radius: 8px; background: white; cursor: pointer; font-size: 0.85rem;"
                    onclick="submitCheckpointDecision('fix', '${currentWorkflowId}', this.closest('.modal-overlay'))">🔧 Fix / Retry</button>
            <button style="padding: 8px 20px; border: 1px solid #ef4444; border-radius: 8px; background: white; color: #ef4444; cursor: pointer; font-size: 0.85rem;"
                    onclick="submitCheckpointDecision('abort', '${currentWorkflowId}', this.closest('.modal-overlay'))">✗ Abort</button>
        </div>
    </div>`;

    document.body.appendChild(modal);
}

// Submit checkpoint decision
async function submitCheckpointDecision(decision, workflowId, modal) {
    try {
        const res = await fetch(`/api/orchestration/${workflowId}/decision`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ decision })
        });

        if (res.ok) {
            modal.remove();
            // Resume polling
            fetchAndUpdateLogs(workflowId);
        } else {
            alert('Failed to submit decision');
        }
    } catch (err) {
        alert('Error: ' + err.message);
    }
}

// Update executeWorkflow to start log polling
const originalExecuteWorkflow = executeWorkflow;
async function executeWorkflow() {
    let input = document.getElementById('execInput').value.trim();
    if (!input && !uploadedFileContent) { alert('Please enter an input prompt or attach a file.'); return; }
    if (uploadedFileContent) {
        input = input ? input + '\n\n[Attached File Content]\n' + uploadedFileContent : uploadedFileContent;
    }

    const btn = document.getElementById('executeBtn');
    const status = document.getElementById('execStatus');
    btn.disabled = true;
    btn.textContent = 'Executing...';
    status.textContent = 'Starting orchestration...';
    status.style.color = 'var(--accent)';

    try {
        const res = await fetch('/api/solutions/' + SOLUTION_ID + '/execute', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ input, broadcastMode: document.getElementById('broadcastMode').checked })
        });
        const data = await res.json();

        if (!res.ok) {
            status.textContent = data.error || 'Execution failed.';
            status.style.color = '#ef4444';
            btn.disabled = false;
            btn.innerHTML = '&#x25B6; Execute Pipeline';
            return;
        }

        // Start log polling for real-time visualization
        if (data.workflow_id) {
            startLogPolling(data.workflow_id);
        }

        status.textContent = 'Pipeline running...';
        status.style.color = 'var(--accent)';
    } catch (err) {
        status.textContent = 'Error: ' + err.message;
        status.style.color = '#ef4444';
    }

    btn.disabled = false;
    btn.innerHTML = '&#x25B6; Execute Pipeline';
}

// Helper to highlight log entries
function highlightLogEntry(agentName) {
    const entries = document.querySelectorAll('#logTimeline > div');
    entries.forEach(e => e.style.opacity = '0.3');
    document.querySelectorAll('#logTimeline > div').forEach(e => {
        if (e.textContent.includes(agentName)) e.style.opacity = '1';
    });
}

// Helper to expand log entry details
function expandLogEntry(el) {
    el.style.backgroundColor = '#eff6ff';
    el.style.borderLeftWidth = '6px';
}

// Initialize on page load
window.addEventListener('load', () => {
    renderGraphStructure();
});
</script>

