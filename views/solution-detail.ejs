// Generate dynamic LangGraph diagram from CURRENT workflow steps in DOM
function generateDynamicDiagram() {
    const diagram = document.getElementById('orchestratorDiagram');
    if (!diagram) {
        console.warn('[DIAGRAM] Diagram element not found');
        return;
    }

    // Read CURRENT steps from the workflow pipeline cards in DOM
    const pipeline = document.getElementById('workflowPipeline');
    if (!pipeline) {
        console.warn('[DIAGRAM] Pipeline not found - no agents added yet');
        return;
    }

    // Select all .workflow-agent cards - using Array.from for compatibility
    const allCards = Array.from(pipeline.querySelectorAll('.workflow-agent'));
    const stepCards = allCards.filter(card => {
        // Ensure it's a direct child (no connector divs in between)
        return card.parentElement === pipeline;
    });

    console.log('[DIAGRAM] Found', stepCards.length, 'direct workflow agent cards');
    const steps = [];

    stepCards.forEach((card, idx) => {
        const nameEl = card.querySelector('.workflow-node-name');
        const endpointEl = card.querySelector('.workflow-node-endpoint');
        const name = nameEl ? nameEl.textContent.trim() : '';
        const endpoint = endpointEl ? endpointEl.textContent.trim() : '';

        if (name || endpoint) {
            steps.push({ name: name || endpoint, endpoint, order: idx });
            console.log('[DIAGRAM] Agent', idx, ':', name, '/', endpoint);
        }
    });

    // Map endpoint names to display info
    const nameMap = {
        'mit_structured_data_profiler_endpoint': { display: 'Profile DataScout', short: 'profiler' },
        'mit_data_quality_agent_endpoint': { display: 'Quality DataGuard', short: 'quality' },
        'mit_data_classifier_endpoint': { display: 'Classify PII Guard', short: 'classifier' },
        'mit_autoloader_agent_endpoint': { display: 'AutoLoad Pipeline', short: 'autoloader' }
    };

    let html = '<div style="display:flex;flex-wrap:wrap;align-items:center;gap:8px;padding:8px;">';

    // START
    html += '<div style="background:#10B981;color:white;padding:6px 12px;border-radius:16px;font-weight:600;font-size:11px;">▶ START</div>';
    html += '<span style="color:#9CA3AF;font-size:16px;">→</span>';

    if (steps.length === 0) {
        html += '<div style="color:#9CA3AF;font-size:11px;padding:8px;"><i>Add agents to see flow</i></div>';
    } else {
        steps.forEach((step, idx) => {
            const info = nameMap[step.endpoint] || { display: step.name, short: step.name.substring(0, 10) };

            // Agent node
            html += `<div style="background:#3B82F6;color:white;padding:6px 10px;border-radius:6px;font-size:10px;text-align:center;"><b>🤖</b><br><span style="font-size:8px;">${info.display.split(' ')[0]}</span></div>`;
            html += '<span style="color:#9CA3AF;font-size:16px;">→</span>';

            // Supervisor node
            html += '<div style="background:#7C3AED;color:white;padding:4px 8px;border-radius:6px;font-size:9px;text-align:center;">🧠<br><span style="font-size:7px;">Sup</span></div>';
            html += '<span style="color:#9CA3AF;font-size:16px;">→</span>';

            // Gate (not after last)
            if (idx < steps.length - 1) {
                html += '<div style="background:#F59E0B;color:white;padding:4px 8px;border-radius:6px;font-size:9px;text-align:center;border:1px dashed #D97706;">⚠️</div>';
                html += '<span style="color:#9CA3AF;font-size:16px;">→</span>';
            }
        });
    }

    // END
    html += '<div style="background:#EF4444;color:white;padding:6px 12px;border-radius:16px;font-weight:600;font-size:11px;">🏁 END</div>';
    html += '</div>';

    diagram.innerHTML = html;
    console.log('[DIAGRAM] Updated with', steps.length, 'agents');
}

