function handleCheckpointDecision(decision, checkpointType) {
    const notification = document.getElementById('checkpointNotification');
    if (notification) {
        notification.style.opacity = '0.6';
        notification.style.pointerEvents = 'none';
    }

    // Log the decision
    console.log('[DECISION] User chose:', decision, 'for checkpoint:', checkpointType);

    // Show confirmation
    setTimeout(() => {
        if (notification) {
            notification.innerHTML = `
                <div style="color: #065F46; font-weight: 700; font-size: 13px;">
                    ✅ Decision recorded: ${decision.toUpperCase()}
                </div>
                <div style="color: #047857; font-size: 12px; margin-top: 6px;">
