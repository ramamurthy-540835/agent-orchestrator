// Log polling variables
let logPollingInterval = null;
let currentWorkflowId = null;
let checkpointModalOpen = false;     // Is the modal currently displayed?
let lastCheckpointId = null;         // Track last checkpoint to avoid duplicates

// Start polling for logs
function startLogPolling(workflowId) {
    currentWorkflowId = workflowId;

    // Show visualization sections
    document.getElementById('executorAnimatorSection').style.display = 'block';
    document.getElementById('logVisualizerSection').style.display = 'block';
    document.getElementById('stateInspectorSection').style.display = 'block';

    // Generate execution flow circles from current workflow steps
    generateExecutionFlowCircles();

    // Poll every 2 seconds for live updates (smooth transitions, visible color changes)
    logPollingInterval = setInterval(() => fetchAndUpdateLogs(workflowId), 2000);

    // First fetch immediately
    fetchAndUpdateLogs(workflowId);
}

// Fetch and update logs in real-time
async function fetchAndUpdateLogs(workflowId) {
    try {
        const resp = await fetch(`/api/orchestration/${workflowId}`);
        const data = await resp.json();

        if (!data) return;

        // Update executor animation
        renderExecutionFlow(data);

        // Update log timeline - ensure log entries render
        if (data.execution_log && Array.isArray(data.execution_log)) {
            renderLogTimeline(data.execution_log);
            // Auto-scroll to bottom
            const timeline = document.getElementById('logTimeline');
            if (timeline) {
                setTimeout(() => { timeline.scrollTop = timeline.scrollHeight; }, 0);
            }
        }

        // Update agent results in real-time (not just at completion)
        if (data.results && Object.keys(data.results).length > 0) {
            renderPipelineResults(data);
        }

        // Update state inspector
        renderStateInspector(data);

        // Update live indicator and show results when complete
        const indicator = document.getElementById('logLiveIndicator');
        if (['COMPLETED', 'FAILED', 'HALTED'].includes(data.status)) {
            clearInterval(logPollingInterval);
            indicator.textContent = `⏹ ${data.status}`;
            indicator.style.color = data.status === 'COMPLETED' ? '#22c55e' : '#ef4444';

            // Show pipeline results when completed
            if (data.status === 'COMPLETED') {
                renderPipelineResults(data);
            }
        } else {
            indicator.textContent = '● LIVE';
            indicator.style.color = '#22c55e';
        }

        // Handle human checkpoints - detect from execution log
        if (data.execution_log && Array.isArray(data.execution_log)) {
            const checkpointEntries = data.execution_log.filter(e => e.event_type === 'HUMAN_CHECKPOINT');
            const latestCheckpoint = checkpointEntries[checkpointEntries.length - 1];

            if (latestCheckpoint && latestCheckpoint.checkpoint_type !== lastCheckpointId) {
                lastCheckpointId = latestCheckpoint.checkpoint_type;
                console.log('[CHECKPOINT] Detected:', latestCheckpoint.checkpoint_type);

                // Show notification and options
                showCheckpointNotification({
                    type: latestCheckpoint.checkpoint_type,
                    question: latestCheckpoint.details?.question || 'Action required',
                    options: latestCheckpoint.details?.options || ['approve', 'fix_retry', 'abort'],
                    agent: latestCheckpoint.agent || 'system'
                });
            }
        }

        // Also handle checkpoint_pending flag if backend sets it
        const checkpointPending = data.checkpoint_pending || data.human_checkpoint_pending;
        if (checkpointPending && !checkpointModalOpen) {
            const checkpointId = data.checkpoint_type || 'unknown';
            if (lastCheckpointId !== checkpointId) {
                lastCheckpointId = checkpointId;
                checkpointModalOpen = true;
                showHumanCheckpointModal(data);
            }
        }

    } catch (err) {
        console.error('Error fetching logs:', err);
    }
}

