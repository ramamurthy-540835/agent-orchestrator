// Execute the workflow
async function executeWorkflow() {
    let input = document.getElementById('execInput').value.trim();
    if (!input && !uploadedFileContent) { alert('Please enter an input prompt or attach a file.'); return; }
    if (uploadedFileContent) {
        input = input ? input + '\n\n[Attached File Content]\n' + uploadedFileContent : uploadedFileContent;
    }

    const btn = document.getElementById('executeBtn');
    const status = document.getElementById('execStatus');
    btn.disabled = true;
    btn.textContent = 'Executing...';
    status.textContent = 'Running pipeline...';
    status.style.color = 'var(--accent)';

    try {
        const res = await fetch('/api/solutions/' + SOLUTION_ID + '/execute', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ input, broadcastMode: document.getElementById('broadcastMode').checked })
        });
        const data = await res.json();

        if (!res.ok) {
            status.textContent = data.error || 'Execution failed.';
            status.style.color = '#ef4444';
            btn.disabled = false;
            btn.innerHTML = '&#x25B6; Execute Pipeline';
            return;
        }

        status.textContent = 'Completed!';
        status.style.color = '#22c55e';
        renderResults(data.results, data.finalOutput);
    } catch (err) {
        status.textContent = 'Error: ' + err.message;
        status.style.color = '#ef4444';
    }

    btn.disabled = false;
    btn.innerHTML = '&#x25B6; Execute Pipeline';
}

function renderResults(results, finalOutput) {
    const container = document.getElementById('execResults');
    const body = document.getElementById('execResultsBody');
    container.style.display = 'block';

    let html = '';
    results.forEach((r, i) => {
        const color = r.status === 'success' ? '#22c55e' : '#ef4444';
        html += `
        <div style="background: var(--gray-50); border: 1px solid var(--border-light); border-radius: 8px; padding: 14px; margin-bottom: 10px; border-left: 3px solid ${color};">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                <strong style="font-size: 0.9rem;">Step ${i + 1}: ${r.stepName}</strong>
                <span style="font-size: 0.75rem; color: ${color}; font-weight: 600;">${r.status.toUpperCase()} (${r.duration}ms)</span>
            </div>
            <div style="font-size: 0.8rem; color: var(--gray-500); margin-bottom: 6px;">Endpoint: ${r.endpoint}</div>
            ${r.error ? `<div style="font-size: 0.8rem; color: #ef4444;">Error: ${r.error}</div>` : ''}
            ${r.output ? `
            <details style="margin-top: 8px;">
                <summary style="font-size: 0.8rem; cursor: pointer; color: var(--accent); font-weight: 500;">View Output</summary>
                <pre style="background: #1E1E1E; color: #D4D4D4; padding: 12px; border-radius: 8px; margin-top: 6px; font-size: 0.8rem; overflow-x: auto; white-space: pre-wrap;">${typeof r.output === 'string' ? escapeHtml(r.output) : escapeHtml(JSON.stringify(r.output, null, 2))}</pre>
            </details>` : ''}
        </div>`;
    });

    if (finalOutput) {
        html += `
        <div style="background: var(--gray-50); border: 2px solid #22c55e; border-radius: 8px; padding: 14px; margin-top: 15px;">
            <strong style="font-size: 0.9rem; color: #22c55e;">Final Output</strong>
            <pre style="background: #1E1E1E; color: #D4D4D4; padding: 12px; border-radius: 8px; margin-top: 8px; font-size: 0.85rem; overflow-x: auto; white-space: pre-wrap;">${typeof finalOutput === 'string' ? escapeHtml(finalOutput) : escapeHtml(JSON.stringify(finalOutput, null, 2))}</pre>
        </div>`;
    }

    body.innerHTML = html;
}

function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
}

