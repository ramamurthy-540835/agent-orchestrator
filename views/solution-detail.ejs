// Helper to highlight log entries
function highlightLogEntry(agentName) {
    const entries = document.querySelectorAll('#logTimeline > div');
    entries.forEach(e => e.style.opacity = '0.3');
    document.querySelectorAll('#logTimeline > div').forEach(e => {
        if (e.textContent.includes(agentName)) e.style.opacity = '1';
    });
}

// Helper to expand log entry details
function expandLogEntry(el) {
    el.style.backgroundColor = '#eff6ff';
    el.style.borderLeftWidth = '6px';
}

// Render pipeline results as expandable cards
function renderPipelineResults(data) {
    const resultsSection = document.getElementById('pipelineResultsSection');
    const resultsBody = document.getElementById('pipelineResultsBody');

    if (!resultsSection || !resultsBody) return;

    resultsSection.style.display = 'block';
    resultsBody.innerHTML = '';

    const agentNames = ['profiler', 'quality', 'classifier', 'autoloader'];
    const results = data.results || {};

    agentNames.forEach(agent => {
        const result = results[agent];
        if (!result) return;

        const isSuccess = result.status === 'SUCCESS';
        const card = document.createElement('div');
        card.style.cssText = 'border:1px solid #E5E7EB;border-radius:8px;overflow:hidden;';

        const header = document.createElement('div');
        header.onclick = function() {
            const content = this.nextElementSibling;
            if (content) {
                content.style.display = content.style.display === 'none' ? 'block' : 'none';
                this.style.backgroundColor = content.style.display === 'block' ? (isSuccess ? '#DCFCE7' : '#FEE2E2') : (isSuccess ? '#F0FDF4' : '#FEF2F2');
            }
        };
        header.style.cssText = `padding:12px 16px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;background:${isSuccess ? '#F0FDF4' : '#FEF2F2'};transition:all 0.2s;`;

        const title = document.createElement('div');
        title.style.cssText = 'display:flex;align-items:center;gap:12px;flex:1;';
        title.innerHTML = `
            <span style="font-weight:600;font-size:15px;">${agent.charAt(0).toUpperCase() + agent.slice(1)}</span>
            <span style="padding:2px 8px;border-radius:12px;font-size:11px;font-weight:500;background:${isSuccess ? '#10B981' : '#EF4444'};color:white;">
                ${result.status}
            </span>
            <span style="color:#6B7280;font-size:12px;">${result.duration_ms}ms</span>
        `;

        const toggle = document.createElement('span');
        toggle.style.cssText = 'color:#6B7280;font-size:14px;';
        toggle.textContent = '▼';

        header.appendChild(title);
        header.appendChild(toggle);

        const content = document.createElement('div');
        content.style.cssText = 'display:none;padding:12px 16px;background:#F9FAFB;max-height:400px;overflow-y:auto;border-top:1px solid #E5E7EB;';
        content.innerHTML = `<pre style="white-space:pre-wrap;word-wrap:break-word;font-size:12px;margin:0;color:#374151;font-family:monospace;">${escapeHtml(result.output || 'No output')}</pre>`;

        card.appendChild(header);
        card.appendChild(content);
        resultsBody.appendChild(card);
    });

    // Add quality score summary
    if (data.quality_score) {
        const summary = document.createElement('div');
        summary.style.cssText = 'background:#EFF6FF;border:1px solid #BFDBFE;border-radius:8px;padding:12px;margin-top:12px;';
        const piiText = data.pii_detected && data.pii_detected.length > 0 ? data.pii_detected.join(', ') : 'None';
        summary.innerHTML = `<div style="font-size:14px;"><b>Quality Score:</b> ${data.quality_score}%</div><div style="font-size:14px;margin-top:6px;"><b>PII Detected:</b> ${piiText}</div>`;
        resultsBody.appendChild(summary);
    }
}

// ============================================================================
// DRAG-AND-DROP FOR PIPELINE CARDS + AVAILABLE AGENTS PANEL
// ============================================================================

let draggedElement = null;

function initDragDrop() {
    console.log('[DRAGDROP] Initializing drag-drop');
    const pipeline = document.getElementById('workflowPipeline');
    if (!pipeline) {
        console.error('[DRAGDROP] Pipeline element not found');
        return false;
    }

    const cards = pipeline.querySelectorAll('.workflow-agent');
    console.log('[DRAGDROP] Found', cards.length, 'cards to make draggable');

    if (cards.length === 0) {
        console.warn('[DRAGDROP] No cards found, will retry later');
        return false;
    }

    cards.forEach((card, idx) => {
        // Ensure draggable attribute is set
        card.draggable = true;
        card.dataset.dragIndex = idx;

        // Add drag listeners
        card.addEventListener('dragstart', function(e) {
            draggedElement = this;
            e.dataTransfer.effectAllowed = 'move';
            this.style.opacity = '0.5';
            this.style.border = '2px dashed #3B82F6';
            console.log('[DRAGDROP] Drag started on card', idx);
        }, false);

        card.addEventListener('dragend', function(e) {
            this.style.opacity = '1';
            this.style.border = '';
            draggedElement = null;
            console.log('[DRAGDROP] Drag ended');
        }, false);

        card.addEventListener('dragover', function(e) {
            e.preventDefault();
            e.dataTransfer.dropEffect = 'move';
            if (draggedElement && draggedElement !== this) {
                this.style.borderLeft = '4px solid #3B82F6';
            }
        }, false);

        card.addEventListener('dragleave', function(e) {
            this.style.borderLeft = '';
        }, false);

        card.addEventListener('drop', function(e) {
            e.preventDefault();
            this.style.borderLeft = '';

            if (draggedElement && draggedElement !== this) {
                console.log('[DRAGDROP] Drop detected');
                const parent = pipeline;
                const allCards = [...parent.querySelectorAll('.workflow-agent')];
                const draggedIdx = allCards.indexOf(draggedElement);
                const targetIdx = allCards.indexOf(this);

                if (draggedIdx >= 0 && targetIdx >= 0) {
                    if (draggedIdx < targetIdx) {
                        this.parentNode.insertBefore(draggedElement, this.nextElementSibling);
                    } else {
                        this.parentNode.insertBefore(draggedElement, this);
                    }
                    saveWorkflowOrder();
                    console.log('[DRAGDROP] Cards reordered:', draggedIdx, '->', targetIdx);
                }
            }
        }, false);
    });

    console.log('[DRAGDROP] Drag-drop initialized successfully on', cards.length, 'cards');
    return true;
}

function saveWorkflowOrder() {
    const pipeline = document.getElementById('workflowPipeline');
    const cards = pipeline.querySelectorAll('.workflow-agent');
    const stepIds = Array.from(cards).map(c => c.dataset.stepId);

    fetch('/api/solutions/' + SOLUTION_ID + '/reorder', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ stepIds })
    }).catch(err => console.log('Save order error:', err));
}

async function addAgentStep(endpointName) {
    const res = await fetch('/api/solutions/' + SOLUTION_ID + '/steps', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            name: endpointName.replace('mit_', '').replace('_endpoint', '').replace(/_/g, ' '),
            endpointName: endpointName,
            inputMapping: 'passthrough',
            description: ''
        })
    });

    if (res.ok) {
        window.location.reload();
    }
}

async function loadAvailableAgents() {
    const list = document.getElementById('available-agents-list');
    if (!list) {
        console.error('[AGENTS] Element not found: available-agents-list');
        return;
    }

    try {
        const wsId = '<%= solution.workspaceId || "default-workspace" %>';
        console.log('[AGENTS] Fetching from: /api/workspaces/' + wsId + '/endpoints');

        const resp = await fetch('/api/workspaces/' + wsId + '/endpoints');
        const data = await resp.json();
        console.log('[AGENTS] Response:', data);

        if (!data.endpoints || data.endpoints.length === 0) {
            console.log('[AGENTS] No endpoints from API, using fallback demo agents');
            // Fallback to demo agents if API returns empty
            const demoAgents = [
                { name: 'mit_structured_data_profiler_endpoint', state: 'READY' },
                { name: 'mit_data_quality_agent_endpoint', state: 'READY' },
                { name: 'mit_data_classifier_endpoint', state: 'READY' },
                { name: 'mit_autoloader_agent_endpoint', state: 'READY' }
            ];
            renderAgentsList(demoAgents);
            return;
        }

        renderAgentsList(data.endpoints);
    } catch(e) {
        console.error('[AGENTS] Error loading agents:', e);
        // Use fallback demo agents on error
        const demoAgents = [
            { name: 'mit_structured_data_profiler_endpoint', state: 'READY' },
            { name: 'mit_data_quality_agent_endpoint', state: 'READY' },
            { name: 'mit_data_classifier_endpoint', state: 'READY' },
            { name: 'mit_autoloader_agent_endpoint', state: 'READY' }
        ];
        renderAgentsList(demoAgents);
    }
}

function renderAgentsList(endpoints) {
    const list = document.getElementById('available-agents-list');
    if (!list) return;

    // Sort: READY first, then by name
    const sorted = endpoints.sort((a, b) => {
        if (a.state === 'READY' && b.state !== 'READY') return -1;
        if (a.state !== 'READY' && b.state === 'READY') return 1;
        return (a.name || '').localeCompare(b.name || '');
    });

    // Group agents by state
    const readyAgents = sorted.filter(ep => ep.state === 'READY');
    const stoppedAgents = sorted.filter(ep => ep.state !== 'READY');

    // Build HTML
    let html = '<div style="font-size: 10px; color: #9CA3AF; margin-bottom: 8px; padding: 6px 4px; border-bottom: 1px solid #E5E7EB; font-weight: 500;">✓ READY</div>';

    // Show ready agents
    if (readyAgents.length > 0) {
        html += readyAgents.map(ep => `
            <div style="background:white;border:1px solid #D1FAE5;border-radius:6px;padding:8px;margin-bottom:6px;display:flex;justify-content:space-between;align-items:center;gap:6px;">
                <div style="font-size:11px;flex:1;">
                    <div style="font-weight:500;color:#1F2937;">🤖 ${(ep.name || '').substring(0,16)}</div>
                    <div style="color:#10B981;font-size:9px;">Ready</div>
                </div>
                <button onclick="addAgentStep('${ep.name}')" style="background:#3B82F6;color:white;border:none;border-radius:4px;padding:4px 8px;font-size:10px;cursor:pointer;white-space:nowrap;font-weight:500;">+ Add</button>
            </div>
        `).join('');
    } else {
        html += '<div style="color:#9CA3AF;font-size:10px;padding:8px;text-align:center;">No ready agents</div>';
    }

    // Show stopped agents if any
    if (stoppedAgents.length > 0) {
        html += '<div style="font-size: 10px; color: #9CA3AF; margin-top: 10px; margin-bottom: 8px; padding: 6px 4px; border-top: 1px solid #E5E7EB; border-bottom: 1px solid #E5E7EB; font-weight: 500;">⊘ STOPPED</div>';
        html += stoppedAgents.map(ep => `
            <div style="background:#F3F4F6;border:1px solid #E5E7EB;border-radius:6px;padding:8px;margin-bottom:6px;display:flex;justify-content:space-between;align-items:center;gap:6px;opacity:0.6;">
                <div style="font-size:11px;flex:1;">
                    <div style="font-weight:500;color:#9CA3AF;">🤖 ${(ep.name || '').substring(0,16)}</div>
                    <div style="color:#9CA3AF;font-size:9px;">${ep.state || 'Stopped'}</div>
                </div>
                <button style="background:#D1D5DB;color:#9CA3AF;border:none;border-radius:4px;padding:4px 8px;font-size:10px;cursor:not-allowed;white-space:nowrap;opacity:0.5;" disabled>+ Add</button>
            </div>
        `).join('');
    }

    list.innerHTML = html;
    console.log('[AGENTS] Rendered', readyAgents.length, 'ready agents,', stoppedAgents.length, 'stopped agents');
}

// Initialize immediately and on page load
console.log('[INIT] Starting initialization');

function initAll() {
    try {
        renderGraphStructure();
        loadAvailableAgents();
        const ddSuccess = initDragDrop();
        if (!ddSuccess) {
            console.log('[INIT] Retrying drag-drop in 1s...');
            setTimeout(initDragDrop, 1000);
        }
    } catch(e) {
        console.error('[INIT] Error:', e);
    }
}

// Try to run immediately
try {
    console.log('[INIT] Running immediate init');
    initAll();
} catch(e) {
    console.error('[INIT] Immediate init error:', e);
}

// Also run on DOMContentLoaded
document.addEventListener('DOMContentLoaded', () => {
    console.log('[INIT] DOMContentLoaded fired');
    initAll();
});

// And on window load as fallback
window.addEventListener('load', () => {
    console.log('[INIT] Window load fired');
    initAll();
});

// Manual triggers with progressive delays
setTimeout(() => {
    console.log('[INIT] Timeout 500ms trigger');
    initAll();
}, 500);

setTimeout(() => {
    console.log('[INIT] Timeout 1s trigger');
    initAll();
}, 1000);

setTimeout(() => {
    console.log('[INIT] Timeout 2s trigger');
    initAll();
}, 2000);
</script>

