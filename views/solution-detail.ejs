function renderAgentsList(agents) {
    const list = document.getElementById('available-agents-list');
    if (!list) return;

    // Sort: Mock agents (READY) first, then Real agents, then by name
    const sorted = agents.sort((a, b) => {
        // Mock agents first (ready)
        if (a.source === 'MOCK' && b.source !== 'MOCK') return -1;
        if (a.source !== 'MOCK' && b.source === 'MOCK') return 1;
        // Then READY state
        if (a.state === 'READY' && b.state !== 'READY') return -1;
        if (a.state !== 'READY' && b.state === 'READY') return 1;
        // Then by name
        return (a.name || '').localeCompare(b.name || '');
    });

    // Group: Mock READY, then Real agents by state
    const mockReady = sorted.filter(a => a.source === 'MOCK' && a.state === 'READY');
    const realReady = sorted.filter(a => a.source !== 'MOCK' && a.state === 'READY');
    const realStopped = sorted.filter(a => a.source !== 'MOCK' && a.state !== 'READY');

    // Build HTML
    let html = '';

    // Show mock agents section
    if (mockReady.length > 0) {
        html += '<div style="font-size: 10px; color: #6366F1; margin-bottom: 8px; padding: 6px 4px; border-bottom: 1px solid #E5E7EB; font-weight: 500;">🔵 MOCK</div>';
        html += mockReady.map(ep => `
            <div style="background:#EEF2FF;border:1px solid #C7D2FE;border-radius:6px;padding:8px;margin-bottom:6px;display:flex;justify-content:space-between;align-items:center;gap:6px;">
                <div style="font-size:11px;flex:1;">
                    <div style="font-weight:500;color:#1F2937;">🤖 ${(ep.display_name || ep.name || '').substring(0,18)}</div>
                    <div style="color:#6366F1;font-size:9px;">Mock</div>
                </div>
                <button onclick="addAgentStep('${ep.name}')" style="background:#6366F1;color:white;border:none;border-radius:4px;padding:4px 8px;font-size:10px;cursor:pointer;white-space:nowrap;font-weight:500;">+ Add</button>
            </div>
        `).join('');
    }

    // Show real READY agents
    if (realReady.length > 0) {
        html += '<div style="font-size: 10px; color: #10B981; margin-top: 10px; margin-bottom: 8px; padding: 6px 4px; border-bottom: 1px solid #E5E7EB; font-weight: 500;">✓ READY</div>';
        html += realReady.map(ep => `
            <div style="background:white;border:1px solid #D1FAE5;border-radius:6px;padding:8px;margin-bottom:6px;display:flex;justify-content:space-between;align-items:center;gap:6px;">
                <div style="font-size:11px;flex:1;">
                    <div style="font-weight:500;color:#1F2937;">🤖 ${(ep.display_name || ep.name || '').substring(0,18)}</div>
                    <div style="color:#10B981;font-size:9px;">Ready</div>
                </div>
                <button onclick="addAgentStep('${ep.name}')" style="background:#3B82F6;color:white;border:none;border-radius:4px;padding:4px 8px;font-size:10px;cursor:pointer;white-space:nowrap;font-weight:500;">+ Add</button>
            </div>
        `).join('');
    }

    // Show stopped agents if any
    if (realStopped.length > 0) {
        html += '<div style="font-size: 10px; color: #9CA3AF; margin-top: 10px; margin-bottom: 8px; padding: 6px 4px; border-top: 1px solid #E5E7EB; border-bottom: 1px solid #E5E7EB; font-weight: 500;">⊘ STOPPED</div>';
        html += realStopped.map(ep => `
            <div style="background:#F3F4F6;border:1px solid #E5E7EB;border-radius:6px;padding:8px;margin-bottom:6px;display:flex;justify-content:space-between;align-items:center;gap:6px;opacity:0.6;">
                <div style="font-size:11px;flex:1;">
                    <div style="font-weight:500;color:#9CA3AF;">🤖 ${(ep.display_name || ep.name || '').substring(0,18)}</div>
                    <div style="color:#9CA3AF;font-size:9px;">${ep.state || 'Stopped'}</div>
                </div>
                <button style="background:#D1D5DB;color:#9CA3AF;border:none;border-radius:4px;padding:4px 8px;font-size:10px;cursor:not-allowed;white-space:nowrap;opacity:0.5;" disabled>+ Add</button>
            </div>
        `).join('');
    }

    if (html === '') {
        html = '<div style="color:#9CA3AF;font-size:10px;padding:8px;text-align:center;">No agents available</div>';
    }

    list.innerHTML = html;
    console.log('[AGENTS] Rendered', mockReady.length, 'mock agents,', realReady.length, 'ready real agents,', realStopped.length, 'stopped agents');
}

// ─── Agent Inventory Modal ───
async function showAgentInventory() {
    const modal = document.getElementById('inventoryModal');
    const statsDiv = document.getElementById('inventoryStats');
    const contentDiv = document.getElementById('inventoryContent');

    // Show loading state
    statsDiv.innerHTML = '<div style="font-size:12px; color:#9CA3AF;">Loading agent inventory...</div>';
    contentDiv.innerHTML = '';

    try {
        const resp = await fetch('/api/agents/inventory');
        const data = await resp.json();

        if (!data.agents || data.agents.length === 0) {
            statsDiv.innerHTML = '';
            contentDiv.innerHTML = '<div style="color:#9CA3AF;text-align:center;padding:20px;">No agents found</div>';
            modal.style.display = 'block';
            return;
        }

        // Render stats
        const { summary } = data;
        statsDiv.innerHTML = `
            <div style="flex:1;background:#F3F4F6;border-radius:6px;padding:10px;text-align:center;">
                <div style="font-size:11px;color:#6B7280;">Real (Databricks)</div>
                <div style="font-size:16px;font-weight:600;color:#1F2937;">${summary.real_ready + summary.real_stopped}</div>
                <div style="font-size:10px;color:#9CA3AF;">Ready: ${summary.real_ready} • Stopped: ${summary.real_stopped}</div>
            </div>
            <div style="flex:1;background:#F3F4F6;border-radius:6px;padding:10px;text-align:center;">
                <div style="font-size:11px;color:#6B7280;">Mock</div>
                <div style="font-size:16px;font-weight:600;color:#1F2937;">${summary.mock}</div>
                <div style="font-size:10px;color:#9CA3AF;">Available</div>
            </div>
        `;

        // Group agents by source
        const realAgents = data.agents.filter(a => a.source === 'DATABRICKS');
        const mockAgents = data.agents.filter(a => a.source === 'MOCK');

        // Create tabs
        let html = `
        <div style="display:flex;gap:8px;margin-bottom:16px;border-bottom:2px solid #E5E7EB;">
            <button onclick="switchAgentTab('production')" id="tab-production"
                    style="padding:8px 16px;border:none;background:none;cursor:pointer;font-weight:600;color:#3B82F6;border-bottom:3px solid #3B82F6;font-size:13px;">
                🔴 PRODUCTION (${realAgents.length})
            </button>
            <button onclick="switchAgentTab('mock')" id="tab-mock"
                    style="padding:8px 16px;border:none;background:none;cursor:pointer;font-weight:600;color:#9CA3AF;border-bottom:3px solid transparent;font-size:13px;">
                🔵 MOCK (${mockAgents.length})
            </button>
        </div>`;

        // Production tab content
        html += `<div id="tab-content-production" style="display:block;">`;
        if (realAgents.length > 0) {
            html += realAgents.map(agent => `
                <div style="background:${agent.state === 'READY' ? '#F0FDF4' : '#FEF2F2'};border:1px solid ${agent.state === 'READY' ? '#D1FAE5' : '#FEE2E2'};border-radius:6px;padding:8px;margin-bottom:6px;">
                    <div style="display:flex;justify-content:space-between;align-items:start;gap:8px;">
                        <div style="flex:1;">
                            <div style="font-weight:500;color:#1F2937;font-size:12px;">${agent.display_name}</div>
                            <div style="font-size:11px;color:#6B7280;margin-top:2px;word-break:break-all;">${agent.name}</div>
                            <div style="display:flex;gap:6px;margin-top:4px;">
                                <span style="background:${agent.state === 'READY' ? '#D1FAE5' : '#FEE2E2'};color:${agent.state === 'READY' ? '#065F46' : '#991B1B'};padding:2px 6px;border-radius:3px;font-size:9px;font-weight:500;">${agent.state === 'READY' ? '✓ READY' : '⊘ ' + agent.state}</span>
                                <span style="background:#E0E7FF;color:#312E81;padding:2px 6px;border-radius:3px;font-size:9px;font-weight:500;">${agent.category}</span>
                            </div>
                        </div>
                    </div>
                </div>
            `).join('');
        } else {
            html += '<p style="color:#9CA3AF;text-align:center;padding:20px;">No Databricks endpoints available</p>';
        }
        html += `</div>`;

        // Mock tab content
        html += `<div id="tab-content-mock" style="display:none;">`;
        if (mockAgents.length > 0) {
            html += mockAgents.map(agent => `
                <div style="background:#F0F9FF;border:1px solid #BAE6FD;border-radius:6px;padding:8px;margin-bottom:6px;">
                    <div style="display:flex;justify-content:space-between;align-items:start;gap:8px;">
                        <div style="flex:1;">
                            <div style="font-weight:500;color:#1F2937;font-size:12px;">${agent.icon} ${agent.display_name}</div>
                            <div style="font-size:11px;color:#6B7280;margin-top:2px;">${agent.name}</div>
                            <div style="display:flex;gap:6px;margin-top:4px;">
                                <span style="background:#DBEAFE;color:#1E40AF;padding:2px 6px;border-radius:3px;font-size:9px;font-weight:500;">✓ READY</span>
                                <span style="background:#FEE2E2;color:#7C2D12;padding:2px 6px;border-radius:3px;font-size:9px;font-weight:500;">MOCK</span>
                                <span style="background:#E0E7FF;color:#312E81;padding:2px 6px;border-radius:3px;font-size:9px;font-weight:500;">${agent.category}</span>
                            </div>
                        </div>
                    </div>
                </div>
            `).join('');
        } else {
            html += '<p style="color:#9CA3AF;text-align:center;padding:20px;">No mock agents available</p>';
        }
        html += `</div>`;

        contentDiv.innerHTML = html;
    } catch (err) {
        console.error('[INVENTORY] Error loading agents:', err);
        statsDiv.innerHTML = '';
        contentDiv.innerHTML = '<div style="color:#EF4444;padding:20px;">Error loading agent inventory: ' + err.message + '</div>';
    }

    modal.style.display = 'block';
}

// Switch between Production and Mock tabs
function switchAgentTab(tab) {
    // Hide all tabs
    document.getElementById('tab-content-production').style.display = 'none';
    document.getElementById('tab-content-mock').style.display = 'none';

    // Remove active styles from all buttons
    document.getElementById('tab-production').style.color = '#9CA3AF';
    document.getElementById('tab-production').style.borderBottom = '3px solid transparent';
    document.getElementById('tab-mock').style.color = '#9CA3AF';
    document.getElementById('tab-mock').style.borderBottom = '3px solid transparent';

    // Show selected tab and activate button
    if (tab === 'production') {
        document.getElementById('tab-content-production').style.display = 'block';
        document.getElementById('tab-production').style.color = '#3B82F6';
        document.getElementById('tab-production').style.borderBottom = '3px solid #3B82F6';
    } else {
        document.getElementById('tab-content-mock').style.display = 'block';
        document.getElementById('tab-mock').style.color = '#3B82F6';
        document.getElementById('tab-mock').style.borderBottom = '3px solid #3B82F6';
    }
    console.log('[TABS] Switched to', tab, 'tab');
}

// Initialize immediately and on page load
console.log('[INIT] Starting initialization');

function initAll() {
    try {
        // Restore mock mode preference from localStorage
        const savedMockMode = localStorage.getItem('useMockMode');
        const mockCheckbox = document.getElementById('useMockMode');
        if (mockCheckbox) {
            if (savedMockMode === 'false') {
                mockCheckbox.checked = false;
                toggleMockMode(mockCheckbox);
            } else {
                mockCheckbox.checked = true;
            }
        }

        generateDynamicDiagram();
        loadAvailableAgents();
        const ddSuccess = initDragDrop();
        if (!ddSuccess) {
            console.log('[INIT] Retrying drag-drop in 1s...');
            setTimeout(initDragDrop, 1000);
        }
    } catch(e) {
        console.error('[INIT] Error:', e);
    }
}

// Try to run immediately
try {
    console.log('[INIT] Running immediate init');
    initAll();
} catch(e) {
    console.error('[INIT] Immediate init error:', e);
}

// Also run on DOMContentLoaded
document.addEventListener('DOMContentLoaded', () => {
    console.log('[INIT] DOMContentLoaded fired');
    initAll();
});

// And on window load as fallback
window.addEventListener('load', () => {
    console.log('[INIT] Window load fired');
    initAll();
});

// Manual triggers with progressive delays
setTimeout(() => {
    console.log('[INIT] Timeout 500ms trigger');
    initAll();
}, 500);

setTimeout(() => {
    console.log('[INIT] Timeout 1s trigger');
    initAll();
}, 1000);

setTimeout(() => {
    console.log('[INIT] Timeout 2s trigger');
    initAll();
}, 2000);
</script>

