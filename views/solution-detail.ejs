// Submit checkpoint decision
async function submitCheckpointDecision(decision, workflowId, modal) {
    try {
        const res = await fetch(`/api/orchestration/${workflowId}/decision`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ decision })
        });

        if (res.ok) {
            modal.remove();
            modalOpen = false;
            checkpointModalOpen = false;  // Mark modal as closed
            // Don't reset lastCheckpointId - keep it so we don't show the same checkpoint again
            // Resume polling after a brief delay
            setTimeout(() => fetchAndUpdateLogs(workflowId), 500);
        } else {
            alert('Failed to submit decision');
            modalOpen = false;
            checkpointModalOpen = false;
        }
    } catch (err) {
        alert('Error: ' + err.message);
        modalOpen = false;
        checkpointModalOpen = false;
    }
}

// Update executeWorkflow to start log polling
const originalExecuteWorkflow = executeWorkflow;
async function executeWorkflow() {
